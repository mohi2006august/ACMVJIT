// helpers
function tint(c,a){return c+Math.round(a*255).toString(16).padStart(2,'0')}
const SBADGE={PASS:'background:#22c55e22;color:#22c55e;border-color:#22c55e44',RUNNING:'background:#f9731622;color:#f97316;border-color:#f9731644',QUEUED:'background:#3a3f4a;color:#6b7280;border-color:#3a3f4a'};

// header nav
const topNav=document.getElementById('topNav');
PHASES.forEach(p=>{
  const b=document.createElement('button');
  b.className='nav-btn';b.textContent=p.short;
  b.onclick=()=>document.getElementById('phase-'+p.id).scrollIntoView({behavior:'smooth'});
  topNav.appendChild(b);
});

// hero pipeline
const heroPipe=document.getElementById('heroPipeline');
PHASES.forEach((p,i)=>{
  const d=document.createElement('div');
  d.className='pip-row';
  d.onclick=()=>document.getElementById('phase-'+p.id).scrollIntoView({behavior:'smooth'});
  d.innerHTML=`
    <div class="pip-icon" style="background:${tint(p.color,.12)};color:${p.color}">0${i+1}</div>
    <div class="pip-meta">
      <div class="pip-name">${p.label}</div>
      <div class="pip-dur">${p.dur}</div>
    </div>
    <div class="pip-badge" style="${SBADGE[p.status]}">${p.status}</div>`;
  heroPipe.appendChild(d);
});

// pipeline bar
const pipeBar=document.getElementById('pipeBar');
PHASES.forEach((p,i)=>{
  const st=document.createElement('div');
  st.className='pipe-stage'+(i===0?' active':'');
  st.id='pstage-'+p.id;
  st.onclick=()=>document.getElementById('phase-'+p.id).scrollIntoView({behavior:'smooth'});
  st.innerHTML=`<div class="ps-inner"><span class="ps-num">0${i+1}</span><span class="ps-name">${p.short}</span></div>`;
  pipeBar.appendChild(st);
  if(i<PHASES.length-1){
    const arr=document.createElement('div');
    arr.className='pipe-arrow';
    pipeBar.appendChild(arr);
  }
});

// sidebar
const sbInner=document.getElementById('sidebarInner');
PHASES.forEach(p=>{
  const a=document.createElement('a');
  a.className='sb-item';a.href='#phase-'+p.id;a.id='sb-'+p.id;
  a.onclick=e=>{e.preventDefault();document.getElementById('phase-'+p.id).scrollIntoView({behavior:'smooth'})};
  a.innerHTML=`
    <div class="sb-dot" style="background:${p.color}"></div>
    <div class="sb-info">
      <div class="sb-name">${p.label}</div>
      <div class="sb-dur">${p.dur}</div>
    </div>`;
  sbInner.appendChild(a);
});

// intersection observer — sidebar + pipeline bar active state
const obsItems=sbInner.querySelectorAll('.sb-item');
const pipeItems=pipeBar.querySelectorAll('.pipe-stage');
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const id=parseInt(e.target.dataset.id);
      obsItems.forEach((it,i)=>it.classList.toggle('active',i===id));
      pipeItems.forEach((it,i)=>it.classList.toggle('active',i===id));
    }
  });
},{threshold:0.2,rootMargin:'-56px 0px -40% 0px'});

// main content
const main=document.getElementById('mainArea');
let openCard=null;

PHASES.forEach(p=>{
  const sec=document.createElement('section');
  sec.className='phase-block';sec.id='phase-'+p.id;sec.dataset.id=p.id;
  io.observe(sec);

  sec.innerHTML=`
    <div class="phase-header">
      <div class="ph-top">
        <div class="ph-tag" style="${SBADGE[p.status]}">job: ${p.status}</div>
        <div class="ph-divider"></div>
        <div class="ph-dur">${p.dur}</div>
      </div>
      <div class="ph-title"><span style="color:${p.color}">${p.label}</span></div>
      <div class="ph-desc">${p.desc}</div>
    </div>
    <div class="cards" id="cards-${p.id}"></div>`;

  main.appendChild(sec);

  const grid=document.getElementById('cards-'+p.id);
  p.cards.forEach((c,i)=>{
    const key=`${p.id}-${i}`;
    const el=document.createElement('div');
    el.className='card';el.id='card-'+key;
    el.innerHTML=`
      <div class="card-head">
        <div class="card-top">
          <div class="card-led" style="background:${p.color};border-color:${p.color}"></div>
          <span class="card-title">${c.title}</span>
        </div>
        <div class="card-tags">${c.tags.map(t=>`<span class="card-tag" style="color:${p.color};border-color:${p.tagBorder};background:${p.tagColor}">${t}</span>`).join('')}</div>
      </div>
      <div class="card-body">
        <div class="card-inner">
          <div class="ci-section">
            <div class="ci-label">what to learn</div>
            <ul class="ci-list">${c.learn.map(l=>`<li>${l}</li>`).join('')}</ul>
          </div>
          <div class="ci-section">
            <div class="ci-label">resources</div>
            <ul class="ci-list">${c.res.map(r=>`<li>${r}</li>`).join('')}</ul>
          </div>
        </div>
        <div class="card-foot">
          <div class="toggle-txt" onclick="toggleCard('${key}')">
            <span class="open-txt">▾ collapse</span>
            <span class="close-txt">▸ expand</span>
          </div>
          <button class="plan-btn" onclick="event.stopPropagation()">study plan →</button>
        </div>
      </div>`;
    el.querySelector('.card-head').onclick=()=>toggleCard(key);
    grid.appendChild(el);
  });
});

function toggleCard(key){
  const el=document.getElementById('card-'+key);
  const was=el.classList.contains('open');
  if(openCard&&openCard!==key){
    const prev=document.getElementById('card-'+openCard);
    if(prev)prev.classList.remove('open');
  }
  el.classList.toggle('open',!was);
  openCard=was?null:key;
}
</script>
</body>
