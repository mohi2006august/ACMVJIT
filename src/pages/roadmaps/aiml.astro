        res:["MLflow docs","Weights & Biases docs","DVC.org tutorials"] },
      { title:"Pipelines & orchestration", tags:["Airflow","Prefect","Kubeflow"],
        learn:["Directed acyclic graph (DAG) concept","Airflow operators & task dependencies","Prefect flows for simpler pipelines","Kubeflow for Kubernetes-native ML","Feature stores (Feast, Hopsworks)"],
        res:["Airflow docs","Prefect docs","Made With ML course (free)"] },
