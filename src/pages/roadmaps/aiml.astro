function hex(c, a) { return c + Math.round(a*255).toString(16).padStart(2,'0'); }

// Build header nav
const nav = document.getElementById('mainNav');
PHASES.forEach(p => {
  const b = document.createElement('button');
  b.className = 'nav-link';
  b.textContent = p.label;
  b.onclick = () => document.getElementById('phase-'+p.id).scrollIntoView({behavior:'smooth'});
  nav.appendChild(b);
});

// Build hero phase list
const hp = document.getElementById('heroPhases');
PHASES.forEach((p,i) => {
  const d = document.createElement('div');
  d.className = 'hp-item';
  d.onclick = () => document.getElementById('phase-'+p.id).scrollIntoView({behavior:'smooth'});
  d.innerHTML = `
    <span class="hp-num">0${i+1}</span>
    <span class="hp-name">${p.label}</span>
    <span class="hp-dur">${p.dur}</span>
    <div class="hp-dot" style="background:${p.color}"></div>`;
  hp.appendChild(d);
});

// Build sidebar nav
const snav = document.getElementById('sidebarNav');
PHASES.forEach(p => {
  const a = document.createElement('a');
  a.className = 'snav-item';
  a.href = '#phase-'+p.id;
  a.onclick = e => { e.preventDefault(); document.getElementById('phase-'+p.id).scrollIntoView({behavior:'smooth'}); };
  a.innerHTML = `
    <div class="snav-dot" style="background:${p.color}"></div>
    <div class="snav-info">
      <div class="snav-name">${p.label}</div>
      <div class="snav-dur">${p.dur}</div>
    </div>`;
  snav.appendChild(a);
});

// Intersection observer for active sidebar state
const snavItems = snav.querySelectorAll('.snav-item');
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const id = parseInt(e.target.dataset.id);
      snavItems.forEach((it,i) => it.classList.toggle('active', i===id));
    }
  });
}, { threshold: 0.25, rootMargin: '-60px 0px -40% 0px' });

// Build main content
const main = document.getElementById('mainContent');
let openCard = null;

PHASES.forEach(p => {
  const sec = document.createElement('section');
  sec.className = 'phase-section';
  sec.id = 'phase-'+p.id;
  sec.dataset.id = p.id;
  observer.observe(sec);

  sec.innerHTML = `
    <div class="ps-header">
      <div class="ps-left">
        <div class="ps-phase-label">${p.phase} / ${p.label}</div>
        <div class="ps-title">
          <span style="color:${p.color}">${p.label}</span>
          <span class="ps-dur">${p.dur}</span>
        </div>
        <p class="ps-desc">${p.desc}</p>
      </div>
      <div class="ps-bar" style="background:${p.color}"></div>
    </div>
    <div class="cards-grid" id="grid-${p.id}"></div>`;

  main.appendChild(sec);

  const grid = document.getElementById('grid-'+p.id);
  p.cards.forEach((c,i) => {
    const cardKey = `${p.id}-${i}`;
    const card = document.createElement('div');
    card.className = 'card';
    card.id = `card-${cardKey}`;
    card.innerHTML = `
      <div class="card-head">
        <div class="card-title-row">
          <div class="card-stripe" style="background:${p.color}"></div>
          <span class="card-title">${c.title}</span>
        </div>
        <div class="card-tags">${c.tags.map(t=>`<span class="card-tag" style="color:${p.color};border-color:${hex(p.color,0.3)};background:${hex(p.color,0.07)}">${t}</span>`).join('')}</div>
      </div>
      <div class="card-expand">
        <div class="card-body">
          <div class="cb-section">
            <div class="cb-label">What to learn</div>
            <ul class="cb-list">${c.learn.map(l=>`<li>${l}</li>`).join('')}</ul>
          </div>
          <div class="cb-section">
            <div class="cb-label">Resources</div>
            <ul class="cb-list">${c.res.map(r=>`<li>${r}</li>`).join('')}</ul>
          </div>
        </div>
        <div class="card-footer">
          <div class="card-toggle" onclick="toggleCard('${cardKey}')">
            <span class="arrow">▲</span> collapse
          </div>
          <button class="deep-btn" onclick="event.stopPropagation();alert('Open in chat: Give me a study plan for ${c.title}')">study plan →</button>
        </div>
      </div>`;
    card.querySelector('.card-head').onclick = () => toggleCard(cardKey);
    grid.appendChild(card);
  });
});

function toggleCard(key) {
  const card = document.getElementById('card-'+key);
  const wasOpen = card.classList.contains('open');
  if (openCard && openCard !== key) {
    document.getElementById('card-'+openCard)?.classList.remove('open');
  }
  card.classList.toggle('open', !wasOpen);
  openCard = wasOpen ? null : key;
}
</script>
</body>
</html>
