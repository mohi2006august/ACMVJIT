---
import Layout from '../layouts/Layout.astro';
import leadsData from '../data/chapterLeads.json';
import membersData from '../data/members.json';
---

<Layout 
  title="Our Team"
  description="Meet the dedicated Executive Board and technical leads of the ACM VJIT Student Chapter. Our leadership drives innovation, research, and community growth."
>

  <div class="relative-z">
    <div class="page-header">
      <div class="container text-center animate-fade-up">
        <h1 style="color: #1a1a1a;">Meet The <span class="text-primary">Team</span></h1>
        <p>The executive leadership directing the strategic and operational initiatives of the ACM VJIT Student Chapter.</p>
      </div>
    </div>

    <section class="section">
    <div class="container">
      <div class="team-grid">
        {
          leadsData.map((lead, index) => {
            const roleParts = lead.role.split(',');
            const primaryRole = roleParts[0];
            const secondaryRole = roleParts.length > 1 ? roleParts[1].trim() : null;
            return (
              <div class="lead-card">
                <div class="card-image-wrapper">
                  {lead.photo ? (
                    <img src={lead.photo} alt={lead.name} />
                  ) : (
                    <div class="photo-placeholder">{lead.name.charAt(0)}</div>
                  )}
                </div>
                <div class="card-info">
                  <div class="role-text">
                    <span class="role-primary">{primaryRole}</span>
                    {secondaryRole && <span class="role-secondary"> • {secondaryRole}</span>}
                  </div>
                  <h3 class="lead-name">{lead.name}</h3>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>

    <!-- New Members Section (Full Screen Width) -->
    <div class="members-section mt-16 animate-fade-up">
      <div class="container">
        <h2 class="text-center section-title">ACM <span class="text-primary">Members</span></h2>
      </div>
      <div class="members-line-container">
          <div class="members-scroll">
            {
              membersData.map((member) => (
                <div class="lead-card member-card">
                  <div class="card-image-wrapper">
                    {member.photo ? (
                      <img src={member.photo} alt={member.name} />
                    ) : (
                      <div class="photo-placeholder">{member.name.charAt(0)}</div>
                    )}
                  </div>
                  <div class="card-info">
                    <div class="role-text">
                      <span class="role-primary">Member</span>
                    </div>
                    <h3 class="lead-name">{member.name}</h3>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
  </section>
  </div>
</Layout>

<script>

  function initScrollAnimations() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.animate-fade-up').forEach(el => {
      observer.observe(el);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initScrollAnimations();
  });
  document.addEventListener('astro:page-load', () => {
    initScrollAnimations();
  });
</script>

<style>
  .relative-z {
    position: relative;
    z-index: 10;
  }

  .page-header {
    background: transparent;
    padding: 6rem 0 4rem;
    border-bottom: none;
  }

  .animate-fade-up {
    opacity: 0;
    transform: translateY(30px);
  }
  
  .animate-fade-up.visible {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  .lead-card {
    background: #ffffff;
    border-radius: 28px;
    padding: 1rem;
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.03);
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.03);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lead-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px -10px rgba(0,0,0,0.08);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 4/4.5;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    background: #fdfdfd;
  }

  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) brightness(1.05);
    transform: scale(1.02);
    transition: filter 0.8s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lead-card:hover .card-image-wrapper img {
    filter: grayscale(0%) brightness(1);
    transform: scale(1.05);
  }
  
  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: rgba(0, 0, 0, 0.05);
    font-weight: 300;
    background: #fdfdfd;
    transition: filter 0.8s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lead-card:hover .photo-placeholder {
    transform: scale(1.05);
  }

  .card-info {
    padding: 0 0.5rem 0.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .role-text {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    color: #8c8c8c;
  }

  .role-primary, .role-secondary {
    color: inherit;
  }

  .lead-name {
    font-size: 1.6rem;
    color: #1a1a1a;
    font-weight: 400;
    margin: 0;
    letter-spacing: -0.01em;
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
    transition: color 0.4s ease;
  }

  /* --- Members Line Section --- */
  .mt-16 {
    margin-top: 6rem;
  }

  .section-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: #1a1a1a;
  }

  .members-line-container {
    width: 100%;
    overflow-x: auto;
    padding: 1rem 0 2rem 0;
    -ms-overflow-style: none;  
    scrollbar-width: none;  
  }
  
  .members-line-container::-webkit-scrollbar { 
    display: none; 
  }

  .members-scroll {
    display: flex;
    gap: 2rem;
    padding: 1rem 5vw 3rem 5vw;
    width: max-content; 
  }

  .member-card {
    min-width: 280px;
    max-width: 280px;
    flex-shrink: 0;
  }
</style>
