---
import Layout from '../layouts/Layout.astro';
import leadsData from '../data/chapterLeads.json';
import membersData from '../data/members.json';
---

<Layout 
  title="Our Team"
  description="Meet the dedicated Executive Board and technical leads of the ACM VJIT Student Chapter. Our leadership drives innovation, research, and community growth."
>

  <div class="relative-z">
    <div class="page-header">
      <div class="container text-center animate-fade-up">
        <h1 style="color: #1a1a1a;">Meet The <span class="text-primary">Team</span></h1>
        <p>The executive leadership directing the strategic and operational initiatives of the ACM VJIT Student Chapter.</p>
      </div>
    </div>

    <section class="section">
    <div class="container">
      <div class="team-grid">
        {
          leadsData.map((lead, index) => {
            const roleParts = lead.role.split(',');
            const primaryRole = roleParts[0];
            const secondaryRole = roleParts.length > 1 ? roleParts[1].trim() : null;
            return (
              <div class="lead-card">
                <div class="card-corner"></div>
                <div class="card-badge">
                  <svg viewBox="0 0 24 24" class="badge-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                  <div class="badge-text">
                    <span class="role-primary">{primaryRole}</span>
                    {secondaryRole && <span class="role-secondary">{secondaryRole}</span>}
                  </div>
                </div>
                <div class="card-photo-wrapper">
                  <div class="card-photo-inner">
                    {lead.photo ? (
                      <img src={lead.photo} alt={lead.name} />
                    ) : (
                      <div class="photo-placeholder">{lead.name.charAt(0)}</div>
                    )}
                  </div>
                </div>
                <h3 class="lead-name">{lead.name}</h3>
              </div>
            );
          })
        }
      </div>
    </div>

    <!-- New Members Section (Full Screen Width) -->
    <div class="members-section mt-16 animate-fade-up">
      <div class="container">
        <h2 class="text-center section-title">ACM <span class="text-primary">Members</span></h2>
      </div>
      <div class="members-line-container">
          <div class="members-scroll">
            {
              membersData.map((member) => (
                <div class="lead-card member-card">
                  <div class="card-corner"></div>
                  <div class="card-badge">
                    <svg viewBox="0 0 24 24" class="badge-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    <div class="badge-text">
                      <span class="role-primary">Member</span>
                    </div>
                  </div>
                  <div class="card-photo-wrapper">
                    <div class="card-photo-inner">
                      {member.photo ? (
                        <img src={member.photo} alt={member.name} />
                      ) : (
                        <div class="photo-placeholder">{member.name.charAt(0)}</div>
                      )}
                    </div>
                  </div>
                  <h3 class="lead-name">{member.name}</h3>
                </div>
              ))
            }
          </div>
        </div>
      </div>
  </section>
  </div>
</Layout>

<script>

  function initScrollAnimations() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.animate-fade-up').forEach(el => {
      observer.observe(el);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initScrollAnimations();
  });
  document.addEventListener('astro:page-load', () => {
    initScrollAnimations();
  });
</script>

<style>
  .relative-z {
    position: relative;
    z-index: 10;
  }

  .page-header {
    background: transparent;
    padding: 6rem 0 4rem;
    border-bottom: none;
  }

  .animate-fade-up {
    opacity: 0;
    transform: translateY(30px);
  }
  
  .animate-fade-up.visible {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  .lead-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  
  .lead-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 114, 206, 0.12);
  }

  .card-corner {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    width: 25px;
    height: 25px;
    border-top: 2px solid rgba(0, 114, 206, 0.3);
    border-left: 2px solid rgba(0, 114, 206, 0.3);
  }

  .card-badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.05) 0%, rgba(0, 210, 255, 0.1) 100%);
    border: 1px solid rgba(0, 114, 206, 0.2);
    padding: 0.4rem 1rem 0.4rem 0.6rem;
    border-radius: 50px;
    margin-left: 1.2rem; 
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    z-index: 2;
  }

  .badge-icon {
    width: 18px;
    height: 18px;
    color: var(--primary-color);
  }

  .badge-text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .role-primary {
    font-size: 0.7rem;
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: 1px;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .role-secondary {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--primary-color);
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 1.2;
    margin-top: 0.1rem;
  }

  .card-photo-wrapper {
    width: 100%;
    aspect-ratio: 4/4.5;
    margin-bottom: 1.5rem;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .card-photo-inner {
    width: 90%;
    height: 95%;
    border-radius: 30px 30px 10px 40px; 
    overflow: hidden;
    transform: rotate(2deg);
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.05) 0%, rgba(0, 210, 255, 0.1) 100%);
    box-shadow: 0 10px 20px rgba(0, 114, 206, 0.08);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .lead-card:hover .card-photo-inner {
    transform: rotate(0deg) scale(1.02);
    box-shadow: 0 15px 30px rgba(0, 114, 206, 0.15);
  }

  .card-photo-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: rotate(-2deg) scale(1.05); 
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: rgba(0, 114, 206, 0.15);
    font-weight: bold;
    transform: rotate(-2deg);
  }

  .lead-name {
    font-size: 1.35rem;
    color: #1a1a1a;
    margin-top: auto;
    font-weight: 700;
    text-align: left;
    padding-left: 0.5rem;
  }

  /* --- Members Line Section --- */
  .mt-16 {
    margin-top: 6rem;
  }

  .section-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: #1a1a1a;
  }

  .members-line-container {
    width: 100%;
    overflow-x: auto;
    padding: 1rem 0 2rem 0;
    -ms-overflow-style: none;  
    scrollbar-width: none;  
  }
  
  .members-line-container::-webkit-scrollbar { 
    display: none; 
  }

  .members-scroll {
    display: flex;
    gap: 2rem;
    padding: 1rem 5vw 3rem 5vw;
    width: max-content; 
  }

  .member-card {
    min-width: 280px;
    max-width: 280px;
    flex-shrink: 0;
  }
</style>
