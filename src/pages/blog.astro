---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog">
  <div class="page-header">
    <div class="container text-center">
      <h1>Latest <span class="text-primary">Insights</span></h1>
      <p>Read about technology, experiences, and updates from our community.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="blog-grid">
        <!-- Blog Post 1 -->
        <article class="blog-card">
          <div class="blog-image placeholder"></div>
          <div class="blog-content">
            <span class="blog-category">Technology</span>
            <h3><a href="#">Getting Started with Astro</a></h3>
            <p>Learn how to build blazing fast websites with the Astro framework, combining performance with an excellent developer experience.</p>
            <div class="blog-meta">
              <span>By Tech Team</span> | <span>Oct 10, 2026</span>
            </div>
          </div>
        </article>

        <!-- Blog Post 2 -->
        <article class="blog-card">
          <div class="blog-image placeholder"></div>
          <div class="blog-content">
            <span class="blog-category">Experience</span>
            <h3><a href="#">My First Hackathon Experience</a></h3>
            <p>A personal journey of participating in a 24-hour hackathon. The challenges faced, the coffee consumed, and the lessons learned.</p>
            <div class="blog-meta">
              <span>By Jane Smith</span> | <span>Sep 25, 2026</span>
            </div>
          </div>
        </article>

        <!-- Blog Post 3 -->
        <article class="blog-card">
          <div class="blog-image placeholder"></div>
          <div class="blog-content">
            <span class="blog-category">Community</span>
            <h3><a href="#">Why Join a Tech Society?</a></h3>
            <p>Discover the immense benefits of joining a college society like ACM. From networking to skill development, it's a game-changer.</p>
            <div class="blog-meta">
              <span>By John Doe</span> | <span>Sep 15, 2026</span>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--bg-secondary);
    padding: 6rem 0 4rem;
    border-bottom: 1px solid var(--border-color);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
  }

  .blog-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    transition: transform 0.3s ease;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 24px rgba(0, 114, 206, 0.1);
  }

  .blog-image {
    width: 100%;
    height: 200px;
    background-size: cover;
    background-position: center;
  }

  .blog-image.placeholder {
    background: linear-gradient(to right bottom, #e0e7ff, #ede9fe);
  }

  .blog-content {
    padding: 1.5rem;
  }

  .blog-category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 114, 206, 0.1);
    color: var(--primary-color);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .blog-content h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .blog-content h3 a {
    transition: color 0.2s ease;
  }
  
  .blog-content h3 a:hover {
    color: var(--primary-color);
  }

  .blog-content p {
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
  }
</style>
