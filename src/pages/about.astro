---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About Us"
  description="Learn about the history, mission, and strategic vision of the ACM VJIT Student Chapter. Discover how we cultivate technical proficiency through research, workshops, and peer mentorship."
>

  <!-- Premium Hero Section -->
  <div class="about-hero">
    <div class="container text-center relative-z">
      <div class="badge animate-fade-up">Our Journey</div>
      <h1 class="hero-title animate-fade-up delay-1">About <span class="text-gradient">ACM VJIT</span></h1>
      <p class="hero-subtitle animate-fade-up delay-2">An overview of our institutional mission, strategic vision, and commitment to advancing the field of computer science.</p>
    </div>
  </div>

  <!-- Content Section with Glassmorphism & premium layout -->
  <section class="section about-content">
    <div class="container content-grid">
      
      <div class="content-text animate-fade-right">
        <div class="text-block">
          <div class="icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="card-icon">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.45m.001 0c0-.093.003-.186.008-.28m0 0c.01-.19.025-.38.046-.569m0 0A14.93 14.93 0 0 1 12 3.69" />
            </svg>
          </div>
          <h2>Our Mission</h2>
          <p>The ACM Student Chapter at Vidya Jyothi Institute of Technology is committed to the advancement of computing as both a rigorous academic discipline and a distinguished profession. We strive to establish an environment that promotes technical proficiency, continuous professional development, and foundational research.</p>
        </div>
        
        <div class="text-block mt-4">
          <div class="icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="card-icon">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          </div>
          <h2>What We Do</h2>
          <p>Our chapter coordinates structured technical initiatives, including algorithmic programming contests, collaborative hackathons, professional seminars, and applied engineering workshops. Our core objective is to align academic curricula with modern industry standards, ensuring comprehensive career readiness for our members.</p>
        </div>
      </div>

      <div class="content-image animate-fade-left">
        <div class="image-wrapper">
          <div class="image-corner-accent"></div>
          <img src="https://res.cloudinary.com/dlz7901m4/image/upload/v1781545171/WhatsApp_Image_2026-06-15_at_23.07.33_gzctqn.jpg" alt="ACM VJIT Student Chapter" class="real-image" />
          
          <div class="glass-card-overlay bottom-left">
            <span class="stat-number">40+</span>
            <span class="stat-label">Active Members</span>
          </div>

          <div class="glass-card-overlay top-right">
            <span class="stat-number">6</span>
            <span class="stat-label">Teams</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Core Values Section -->
  <section class="section core-values">
    <div class="container text-center scroll-reveal">
      <h2 style="font-size: 2.5rem; margin-bottom: 3rem;">Our Core <span class="text-primary">Values</span></h2>
      <div class="values-grid">
        <div class="value-card animate-fade-up delay-1">
          <div class="value-icon-box" style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(139, 92, 246, 0.05)); color: #8b5cf6;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1.5.5 2.8 1.5 3.5.76.76 1.23 1.52 1.41 2.5"/></svg>
          </div>
          <h3>Innovation</h3>
          <p>We push the boundaries of conventional learning by exploring emerging technologies like AI, Blockchain, and Cloud architectures.</p>
        </div>
        <div class="value-card animate-fade-up delay-2">
          <div class="value-icon-box" style="background: linear-gradient(135deg, rgba(0, 114, 206, 0.15), rgba(0, 114, 206, 0.05)); color: #0072ce;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Community</h3>
          <p>We foster a highly collaborative environment where peer mentorship and open-source contributions thrive.</p>
        </div>
        <div class="value-card animate-fade-up delay-3">
          <div class="value-icon-box" style="background: linear-gradient(135deg, rgba(233, 30, 99, 0.15), rgba(233, 30, 99, 0.05)); color: #e91e63;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          </div>
          <h3>Excellence</h3>
          <p>Through rigorous competitive coding and elite hackathons, we prepare our members for top-tier industry standards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="section timeline-section">
    <div class="container text-center scroll-reveal">
      <h2 style="font-size: 2.5rem; margin-bottom: 4rem;">Our <span class="text-primary">Journey</span></h2>
      
      <div class="snake-timeline">
        
        <div class="timeline-item animate-fade-up delay-1">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <span class="timeline-date">08 APR '26</span>
            <h3 class="timeline-title">ACM Launchpad</h3>
          </div>
        </div>

        <div class="timeline-item animate-fade-up delay-2">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <span class="timeline-date">08 APR '26</span>
            <h3 class="timeline-title">Codestorm</h3>
          </div>
        </div>

        <div class="timeline-item animate-fade-up delay-3">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <span class="timeline-date">09 APR '26</span>
            <h3 class="timeline-title">Redesignx</h3>
          </div>
        </div>

        <div class="timeline-item animate-fade-up delay-4">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <span class="timeline-date">09 APR '26</span>
            <h3 class="timeline-title">AI Battle</h3>
          </div>
        </div>

      </div>

    </div>
  </section>

</Layout>

<script>
  function initScrollAnimations() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.animate-fade-up, .animate-fade-right, .animate-fade-left').forEach(el => {
      observer.observe(el);
    });
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    initScrollAnimations();
  });
  
  document.addEventListener('astro:page-load', () => {
    initScrollAnimations();
  });
</script>

<style>

  /* --- Premium Hero Section --- */
  .about-hero {
    position: relative;
    padding: 10rem 0 8rem;
    background-color: transparent;
    overflow: hidden;
    border-bottom: 1px solid rgba(0, 114, 206, 0.1);
  }

  .relative-z {
    position: relative;
    z-index: 10;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: rgba(0, 114, 206, 0.1);
    color: var(--primary-color);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(0, 114, 206, 0.2);
  }

  .hero-title {
    font-size: 4.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: -1.5px;
    color: #1a1a1a;
  }

  .text-gradient {
    background: linear-gradient(to right, #0072CE, #00d2ff);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: #555;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* --- Content Grid --- */
  .about-content {
    padding: 6rem 0;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .text-block {
    background: #ffffff;
    padding: 2.5rem;
    border-radius: 20px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    border: 1px solid #f1f5f9;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  /* Subtle top gradient accent on hover */
  .text-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(to right, #0072CE, #00d2ff);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .text-block:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px -5px rgba(0, 114, 206, 0.1), 0 10px 20px -5px rgba(0, 114, 206, 0.05);
    border-color: rgba(0, 114, 206, 0.2);
  }

  .text-block:hover::before {
    transform: scaleX(1);
  }

  .mt-4 { margin-top: 2rem; }

  .text-block:hover .icon-box {
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.15) 0%, rgba(0, 210, 255, 0.15) 100%);
    border-color: rgba(0, 114, 206, 0.3);
    transform: scale(1.05) rotate(-5deg);
  }

  .icon-box {
    width: 64px;
    height: 64px;
    background: rgba(241, 245, 249, 0.8);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all 0.4s ease;
  }

  .card-icon {
    width: 32px;
    height: 32px;
    color: var(--primary-color);
  }

  .text-block h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #1a1a1a;
  }

  .text-block p {
    color: #555;
    line-height: 1.7;
    margin: 0;
    font-size: 1.05rem;
  }

  /* --- Premium Image Wrapper --- */
  .image-wrapper {
    position: relative;
    border-radius: 24px;
    z-index: 1;
  }

  .image-corner-accent {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 150px;
    height: 150px;
    border-top: 4px solid var(--primary-color);
    border-right: 4px solid var(--primary-color);
    border-radius: 0 30px 0 0;
    z-index: -1;
    opacity: 0.5;
  }

  .real-image {
    width: 100%;
    height: 550px;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
  }

  .glass-card-overlay {
    position: absolute;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(15px);
    padding: 1.5rem 2.5rem;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    border: 1px solid rgba(255,255,255,0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .glass-card-overlay.bottom-left {
    bottom: -30px;
    left: -30px;
    animation: float 6s ease-in-out infinite;
  }

  .glass-card-overlay.top-right {
    top: -20px;
    right: -20px;
    animation: float-reverse 7s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes float-reverse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(10px); }
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 800;
    color: var(--primary-color);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #555;
  }

  /* --- Smooth Scroll Animations --- */
  .animate-fade-up, .animate-fade-right, .animate-fade-left {
    opacity: 0;
  }
  
  .animate-fade-up.visible {
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .animate-fade-right.visible {
    animation: fadeRight 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .animate-fade-left.visible {
    animation: fadeLeft 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .delay-1 { animation-delay: 0.2s; }
  .delay-2 { animation-delay: 0.4s; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeRight {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes fadeLeft {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* --- Responsive --- */
  @media (max-width: 992px) {
    .content-grid { gap: 3rem; }
    .hero-title { font-size: 3.5rem; }
    .real-image { height: 450px; }
  }

  @media (max-width: 768px) {
    .content-grid { grid-template-columns: 1fr; }
    .hero-title { font-size: 2.5rem; }
    .about-hero { padding: 6rem 1.5rem 4rem; }
    .real-image { height: 350px; }
    .image-corner-accent { display: none; }
    
    .glass-card-overlay.bottom-left {
      bottom: -20px;
      left: 50%;
      transform: translateX(-50%);
      width: 85%;
      animation: none;
      padding: 1.25rem;
      z-index: 2;
    }
    
    .glass-card-overlay.top-right {
      top: -20px;
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      width: 85%;
      animation: none;
      padding: 1.25rem;
      z-index: 1;
      display: none; /* Hide secondary stat on mobile to save space */
    }
  }

  /* --- Core Values --- */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .value-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 3rem 2rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .value-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 4px;
    background: linear-gradient(90deg, var(--primary-color), #00d2ff, #8b5cf6, var(--primary-color));
    background-size: 300% 100%;
    transform: scaleX(0);
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    transform-origin: left;
  }

  .value-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 114, 206, 0.1), inset 0 0 0 1px rgba(255,255,255,1);
    background: rgba(255, 255, 255, 0.95);
  }

  .value-card:hover::before {
    transform: scaleX(1);
    animation: gradientMove 3s linear infinite;
  }

  @keyframes gradientMove {
    0% { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  .value-icon-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 16px;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    border: 1px solid rgba(255, 255, 255, 0.5);
    transition: transform 0.3s ease;
  }

  .value-card:hover .value-icon-box {
    transform: scale(1.1) rotate(-5deg);
  }

  .value-card h3 {
    font-size: 1.5rem;
    color: #1a1a1a;
    margin-bottom: 1rem;
  }

  /* --- Responsive Timeline --- */
  .timeline-section {
    padding: 4rem 0 8rem;
    overflow: hidden;
  }

  .timeline-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 0.25rem;
    white-space: nowrap;
  }

  .timeline-date {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--primary-color);
    background: rgba(0, 114, 206, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    margin-bottom: 0.5rem;
  }

  /* Desktop View: Horizontal Timeline */
  @media (min-width: 769px) {
    .snake-timeline {
      display: flex;
      justify-content: space-between;
      position: relative;
      padding: 8rem 0;
      margin: 0 2rem;
    }
    
    .snake-timeline::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--primary-color), #00d2ff);
      transform: translateY(-50%);
      z-index: 0;
      border-radius: 4px;
    }

    .timeline-item {
      position: relative;
      z-index: 1;
      width: 25%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .timeline-item:nth-child(odd) .timeline-content {
      transform: translateY(-140%);
    }
    
    .timeline-item:nth-child(even) .timeline-content {
      transform: translateY(140%);
    }

    .timeline-dot {
      width: 24px;
      height: 24px;
      background: #fff;
      border: 4px solid var(--primary-color);
      border-radius: 50%;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      box-shadow: 0 0 0 6px rgba(0, 114, 206, 0.1);
      transition: all 0.3s ease;
    }

    .timeline-item:hover .timeline-dot {
      background: var(--primary-color);
      transform: translate(-50%, -50%) scale(1.3);
      box-shadow: 0 0 15px rgba(0, 210, 255, 0.5);
    }
  }

  /* Mobile View: Wavy Path (Snake Timeline) */
  @media (max-width: 768px) {
    .snake-timeline {
      position: relative;
      max-width: 100%;
      margin: 0 auto;
      padding: 2rem 0;
    }

    .timeline-item {
      position: relative;
      padding: 3rem 0;
      width: 100%;
      height: 160px;
      display: flex;
      align-items: center;
    }

    .timeline-item::before {
      content: "";
      position: absolute;
      top: 0;
      width: 50%;
      height: 100%;
      border: 4px solid var(--primary-color);
      z-index: 0;
    }

    .timeline-item:nth-child(odd)::before {
      left: 50%;
      border-left: none;
      border-radius: 0 60px 60px 0;
    }

    .timeline-item:nth-child(even)::before {
      right: 50%;
      border-right: none;
      border-radius: 60px 0 0 60px;
    }

    .timeline-item:not(:first-child)::before {
      border-top: none;
    }

    .timeline-dot {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 20px;
      height: 20px;
      background: #fff;
      border: 4px solid var(--primary-color);
      border-radius: 50%;
      z-index: 2;
    }

    .timeline-content {
      position: relative;
      width: 45%;
      z-index: 3;
    }

    .timeline-item:nth-child(odd) .timeline-content {
      margin-left: 2%;
      text-align: right;
    }

    .timeline-item:nth-child(even) .timeline-content {
      margin-left: 53%;
      text-align: left;
    }
  }
</style>
