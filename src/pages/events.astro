---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Events">
  <div class="page-header relative overflow-hidden">
    <div class="container text-center relative z-10 scroll-reveal">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Upcoming <span class="text-primary">Events</span></h1>
      <p class="text-lg text-muted delay-1">Join us in our latest activities, tech sessions, and massive hackathons.</p>
    </div>
  </div>

  <section class="section py-16">
    <div class="container">
      <div class="events-list">
        <!-- Event Card 1 -->
        <div class="event-card scroll-reveal delay-1">
          <div class="event-date">
            <span class="day">15</span>
            <span class="month">OCT</span>
          </div>
          <div class="event-details">
            <div class="event-badge">Bootcamp</div>
            <h3>Web Development Bootcamp</h3>
            <p>A 3-day intensive bootcamp covering React, Astro, and TailwindCSS to kickstart your frontend journey.</p>
            <div class="event-meta">
              <span>📍 Block A Auditorium</span>
              <span class="meta-divider">•</span>
              <span>⏰ 10:00 AM - 4:00 PM</span>
            </div>
          </div>
          <div class="event-action">
            <button class="btn btn-primary btn-glow">Register Now</button>
          </div>
        </div>

        <!-- Event Card 2 -->
        <div class="event-card scroll-reveal delay-2">
          <div class="event-date">
            <span class="day">28</span>
            <span class="month">OCT</span>
          </div>
          <div class="event-details">
            <div class="event-badge hackathon">Hackathon</div>
            <h3>Hack-a-thon VJIT 2026</h3>
            <p>Our premier annual 24-hour hackathon. Build innovative solutions for real-world problems and win massive prizes.</p>
            <div class="event-meta">
              <span>📍 Main Library</span>
              <span class="meta-divider">•</span>
              <span>⏰ 9:00 AM (24 Hrs)</span>
            </div>
          </div>
          <div class="event-action">
            <button class="btn btn-outline">Learn More</button>
          </div>
        </div>

        <!-- Event Card 3 -->
        <div class="event-card scroll-reveal delay-3">
          <div class="event-date">
            <span class="day">05</span>
            <span class="month">NOV</span>
          </div>
          <div class="event-details">
            <div class="event-badge guest-lecture">Guest Lecture</div>
            <h3>AI in Modern Web</h3>
            <p>An exclusive talk by industry experts on integrating LLMs and generative AI into modern web applications.</p>
            <div class="event-meta">
              <span>📍 Virtual (Zoom)</span>
              <span class="meta-divider">•</span>
              <span>⏰ 6:00 PM - 8:00 PM</span>
            </div>
          </div>
          <div class="event-action">
            <button class="btn btn-outline">RSVP</button>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  function initEventsJS() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target); 
        }
      });
    }, observerOptions);

    const revealElements = document.querySelectorAll('.scroll-reveal');
    revealElements.forEach(el => observer.observe(el));
  }

  document.addEventListener('DOMContentLoaded', initEventsJS);
  document.addEventListener('astro:page-load', initEventsJS);
</script>

<style>
  .page-header {
    background: linear-gradient(180deg, rgba(0, 114, 206, 0.05) 0%, transparent 100%);
    padding: 8rem 0 5rem;
    border-bottom: 1px solid rgba(0, 114, 206, 0.05);
  }

  .text-4xl { font-size: 2.5rem; }
  @media (min-width: 768px) { .text-4xl { font-size: 3.5rem; } }
  .font-bold { font-weight: 800; letter-spacing: -1px; margin-bottom: 1rem; }
  .text-lg { font-size: 1.125rem; }
  .text-muted { color: var(--text-muted); }
  .py-16 { padding-top: 4rem; padding-bottom: 8rem; }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 950px;
    margin: 0 auto;
  }

  .event-card {
    display: flex;
    align-items: center;
    background: #ffffff;
    padding: 2rem 2.5rem;
    border-radius: 24px;
    border: 1px solid rgba(0, 0, 0, 0.04);
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .event-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0; width: 6px;
    background: linear-gradient(to bottom, var(--primary-color), #00d2ff);
    transform: scaleY(0);
    transform-origin: center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .event-card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 25px 50px rgba(0, 114, 206, 0.12);
    border-color: rgba(0, 114, 206, 0.1);
  }

  .event-card:hover::before {
    transform: scaleY(1);
  }

  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 110px;
    height: 110px;
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.06) 0%, rgba(0, 210, 255, 0.12) 100%);
    border-radius: 20px;
    margin-right: 3rem;
    color: var(--primary-color);
    border: 1px solid rgba(0, 114, 206, 0.1);
    transition: all 0.4s ease;
  }

  .event-card:hover .event-date {
    transform: scale(1.05) rotate(-3deg);
    background: linear-gradient(135deg, var(--primary-color) 0%, #00d2ff 100%);
    color: white;
    box-shadow: 0 10px 20px rgba(0, 114, 206, 0.2);
  }

  .event-date .day {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1;
  }

  .event-date .month {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin-top: 4px;
  }

  .event-details {
    flex: 1;
  }

  .event-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    background: rgba(0, 114, 206, 0.1);
    color: var(--primary-color);
    font-size: 0.75rem;
    font-weight: 800;
    border-radius: 999px;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .event-badge.hackathon {
    background: rgba(156, 39, 176, 0.1);
    color: #9c27b0;
  }

  .event-badge.guest-lecture {
    background: rgba(255, 152, 0, 0.1);
    color: #f57c00;
  }

  .event-details h3 {
    font-size: 1.6rem;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .event-details p {
    color: #555;
    margin-bottom: 1.25rem;
    line-height: 1.6;
    font-size: 1.05rem;
  }

  .event-meta {
    font-size: 0.9rem;
    color: #777;
    display: flex;
    align-items: center;
    font-weight: 600;
  }

  .meta-divider {
    margin: 0 0.85rem;
    color: #ccc;
  }

  .event-action {
    margin-left: 3rem;
  }

  .btn-glow {
    position: relative;
    overflow: hidden;
  }
  .btn-glow::after {
    content: '';
    position: absolute;
    top: -50%; left: -50%; width: 200%; height: 200%;
    background: rgba(255,255,255,0.25);
    transform: rotate(45deg) translate(-50%, -50%);
    animation: button-shine 3s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  @keyframes button-shine {
    0% { transform: translateX(-150%) rotate(45deg); }
    30%, 100% { transform: translateX(150%) rotate(45deg); }
  }

  /* --- Scroll Reveal Animations --- */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.25s; }
  .delay-3 { transition-delay: 0.4s; }

  @media (max-width: 768px) {
    .event-card {
      flex-direction: column;
      text-align: center;
      padding: 2.5rem 1.5rem;
    }
    .event-card::before {
      top: 0; left: 0; right: 0; bottom: auto; height: 6px; width: 100%;
      transform: scaleX(0);
    }
    .event-card:hover::before {
      transform: scaleX(1);
    }
    .event-date {
      margin-right: 0;
      margin-bottom: 1.5rem;
      width: 100%;
      max-width: 140px;
    }
    .event-meta {
      flex-direction: column;
      gap: 0.5rem;
      justify-content: center;
    }
    .meta-divider {
      display: none;
    }
    .event-action {
      margin-left: 0;
      margin-top: 2rem;
      width: 100%;
    }
    .event-action .btn {
      width: 100%;
    }
  }
</style>
