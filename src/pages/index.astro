---
import Layout from '../layouts/Layout.astro';
import leadsData from '../data/leads.json';
---

<Layout 
  title="Home" 
  isHome={true}
  description="Welcome to the official ACM VJIT Student Chapter. Join the ultimate CSE(AI&ML) community at Vidya Jyothi Institute of Technology. Explore coding hackathons, technical seminars, open-source projects, and industry networking."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-single" style="position: relative; z-index: 2;">
      <div class="hero-badge"><span id="typewriter"></span><span class="cursor">|</span></div>
      
      <h1 class="hero-title-aesthetic">
        ACM VJIT
      </h1>

      <p class="hero-subtitle centered-subtitle">
        We bring together students passionate about computing — from algorithms to applications. Through events, mentorship, and a strong community, we turn concepts into working solutions.
      </p>
      
      <div class="hero-actions centered-actions">
        <a href="/recruitment" class="btn btn-primary">Join ACM VJIT</a>
        <a href="/events" class="btn btn-outline">Explore Events</a>
      </div>
    </div>
  </section>


  <!-- About Snippet Section -->
  <section class="section about-snippet scroll-reveal">
    <div class="container snippet-grid">
      <div class="snippet-image delay-1">
        <div class="real-image-wrapper">
          <img src="https://res.cloudinary.com/dlz7901m4/image/upload/v1780600879/WhatsApp_Image_2026-06-05_at_00.37.57_qbqzp0.jpg" alt="ACM VJIT Auditorium Event" class="real-image" />
        </div>
      </div>
      <div class="snippet-content delay-2">
        <h2 class="snippet-title">Cultivating Technical<br /><span class="text-primary">Proficiency</span></h2>
        <p class="snippet-desc">The ACM VJIT Student Chapter is a dedicated academic and professional organization. We facilitate the transition from theoretical computing principles to applied industry practices. Our initiatives provide members with comprehensive technical skill development, structured mentorship programs, and exposure to cutting-edge research.</p>

        <a href="/about" class="btn btn-outline btn-rect" style="margin-top: 1.5rem;">Read Our Story</a>
      </div>
    </div>
  </section>

  <!-- Institution Leads Section -->
  <section class="section leads scroll-reveal">
    <div class="container">
      <div class="text-center" style="margin-bottom: 4rem;">
        <h2 class="snippet-title">Institution <span class="text-primary">Leads</span></h2>
        <p class="snippet-desc" style="max-width: 600px; margin-left: auto; margin-right: auto;">Meet the distinguished leadership driving the strategic vision of ACM VJIT.</p>
      </div>
      <div class="leads-grid">
        {
          leadsData.map((lead, index) => {
            const roleParts = lead.role.split(',');
            const primaryRole = roleParts[0];
            const secondaryRole = roleParts.length > 1 ? roleParts[1].trim() : null;
            return (
              <div class={`lead-card delay-${(index % 4) + 1}`}>
                <div class="card-image-wrapper">
                  {lead.photo ? (
                    <img src={lead.photo} alt={lead.name} />
                  ) : (
                    <div class="photo-placeholder">{lead.name.charAt(0)}</div>
                  )}
                </div>
                <div class="card-info">
                  <div class="role-text">
                    <span class="role-primary">{primaryRole}</span>
                    {secondaryRole && <span class="role-secondary"> • {secondaryRole}</span>}
                  </div>
                  <h3 class="lead-name">{lead.name}</h3>
                </div>
              </div>
            );
          })
        }
      </div>
      <div class="text-center" style="margin-top: 3.5rem;">
        <a href="/team" class="btn btn-outline">View Full Team</a>
      </div>
    </div>
  </section>

  <!-- Join Us CTA Section -->
  <section class="section join-cta scroll-reveal">
    <div class="container">
      <div class="cta-card">
        <div class="cta-icon-badge">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h2 class="cta-title-aesthetic">Ready to Innovate?</h2>
        <p class="cta-desc">Become a member of Vidya Jyothi Institute of Technology's premier computing community. Expand your skills, collaborate on projects, and lead the future of technology.</p>
        <div class="cta-action">
          <a href="/recruitment" class="btn btn-primary btn-large btn-rect">Join Us Now</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  function initHomeJS() {
    // 1. Intersection Observer for scroll animations
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target); 
        }
      });
    }, observerOptions);

    const revealElements = document.querySelectorAll('.scroll-reveal');
    revealElements.forEach(el => observer.observe(el));

    // 2. Typewriter Effect for Hero Tagline
    const words = [
      "From algorithms to applications.",
      "Where curiosity meets computing.",
      "Learn. Build. Compute.",
      "Turning ideas into working solutions.",
      "Code with purpose.",
      "Computing, powered by community."
    ];
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    const typedTextSpan = document.getElementById("typewriter");
    
    if(typedTextSpan) {
      typedTextSpan.textContent = "";

      function typeSubtitle() {
        if(!typedTextSpan) return;
        const currentWord = words[wordIndex];
        if (isDeleting) {
          typedTextSpan.textContent = currentWord.substring(0, charIndex - 1);
          charIndex--;
        } else {
          typedTextSpan.textContent = currentWord.substring(0, charIndex + 1);
          charIndex++;
        }
        
        let typeSpeed = isDeleting ? 20 : 60;
        
        if (!isDeleting && charIndex === currentWord.length) {
          typeSpeed = 2500;
          isDeleting = true;
        } else if (isDeleting && charIndex === 0) {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          typeSpeed = 500;
        }
        
        setTimeout(typeSubtitle, typeSpeed);
      }
      setTimeout(typeSubtitle, 1000);
    }

  }

  document.addEventListener('DOMContentLoaded', initHomeJS);
  document.addEventListener('astro:page-load', initHomeJS);
</script>

<style>
  /* --- Hero Section (Centered Layout) --- */
  .hero {
    padding: 8rem 0 6rem;
    position: relative;
    overflow: hidden;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: calc(100vh - 80px); /* 80px for header approx */
    justify-content: center;
  }

  .hero-single {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }
  
  .centered-subtitle {
    margin: 0 auto 2rem auto;
    text-align: center;
  }
  
  .centered-actions {
    justify-content: center;
  }

  .hero-title-aesthetic {
    font-size: clamp(4.5rem, 12vw, 9rem);
    font-weight: 400;
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
    color: #1a1a1a;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem 0;
    opacity: 0;
    transform: translateY(30px);
    animation: cinematicEnter 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.3s;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    background: #ffffff;
    color: #1a1a1a;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    border: 1px solid rgba(0, 0, 0, 0.04);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    opacity: 0;
    transform: translateY(20px);
    animation: cinematicEnter 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .cursor {
    display: inline-block;
    width: 1px;
    height: 1.2em;
    background-color: #a0aec0;
    margin-left: 4px;
    animation: blink 1s infinite;
    vertical-align: middle;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-subtitle, .hero-actions {
    opacity: 0;
    transform: translateY(30px);
    animation: cinematicEnter 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    margin-bottom: 3rem;
    color: #1a1a1a;
    font-weight: 400;
    animation-delay: 0.5s;
    line-height: 1.8;
    max-width: 680px;
  }

  .hero-actions {
    display: flex;
    justify-content: flex-start;
    gap: 1.5rem;
    animation-delay: 0.7s;
    flex-wrap: wrap;
  }

  .hero-actions .btn {
    padding: 1rem 2.5rem;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 999px;
    letter-spacing: 0.02em;
    transition: all 0.4s ease;
  }

  .hero-actions .btn-primary {
    background-color: #1a1a1a;
    background-image: none;
    color: #ffffff;
    border: none;
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.15);
  }
  
  .hero-actions .btn-primary:hover {
    background-color: var(--primary-color, #0072CE);
    transform: translateY(-2px);
    box-shadow: 0 15px 35px -10px rgba(0, 114, 206, 0.3);
  }

  .hero-actions .btn-outline {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.1);
    color: #1a1a1a;
  }
  
  .hero-actions .btn-outline:hover {
    background: #fdfdfd;
    border-color: rgba(0,0,0,0.2);
    color: #1a1a1a !important;
  }

  @keyframes cinematicEnter {
    0% { 
      opacity: 0; 
      transform: translateY(40px); 
      filter: blur(5px); 
    }
    100% { 
      opacity: 1; 
      transform: translateY(0); 
      filter: blur(0px); 
    }
  }

  @keyframes fadeUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .btn-glow {
    position: relative;
    overflow: hidden;
  }
  
  .btn-glow::after {
    content: '';
    position: absolute;
    top: -50%; left: -50%; width: 200%; height: 200%;
    background: rgba(255,255,255,0.3);
    transform: rotate(45deg) translate(-50%, -50%);
    animation: button-shine 3s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes button-shine {
    0% { transform: translateX(-150%) rotate(45deg); }
    30%, 100% { transform: translateX(150%) rotate(45deg); }
  }

  /* --- Scroll Animations Base --- */
  .scroll-reveal > *, .scroll-reveal .feature-card, .scroll-reveal .stat-card, .scroll-reveal .snippet-image, .scroll-reveal .snippet-content, .scroll-reveal .cta-box {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-reveal.in-view > *, .scroll-reveal.in-view .feature-card, .scroll-reveal.in-view .stat-card, .scroll-reveal.in-view .snippet-image, .scroll-reveal.in-view .snippet-content, .scroll-reveal.in-view .cta-box {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-1 { transition-delay: 0.1s !important; }
  .delay-2 { transition-delay: 0.25s !important; }
  .delay-3 { transition-delay: 0.4s !important; }
  .delay-4 { transition-delay: 0.55s !important; }



  /* --- About Snippet Section --- */
  .about-snippet {
    background: linear-gradient(to bottom, transparent, rgba(0, 114, 206, 0.02), transparent);
    padding: 8rem 0;
  }

  .snippet-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .snippet-title {
    font-size: 2.6rem;
    font-weight: 400;
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
    color: #1a1a1a;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .snippet-desc {
    color: #1a1a1a;
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .real-image-wrapper {
    width: 100%;
    height: 400px;
    position: relative;
    border-radius: 24px;
  }
  
  .real-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.1);
  }

  .real-image-wrapper::after {
    content: '';
    position: absolute;
    inset: -15px;
    border: 1px dashed rgba(0, 114, 206, 0.3);
    border-radius: 36px;
    z-index: -1;
  }



  .btn-rect {
    border-radius: 8px !important;
    padding: 0.75rem 2rem !important;
    font-weight: 600 !important;
    border: 1px solid var(--primary-color) !important;
    color: var(--primary-color) !important;
    font-size: 0.95rem !important;
  }
  .btn-rect:hover {
    background-color: rgba(0, 114, 206, 0.05) !important;
  }

  /* --- Leads Section --- */
  .leads {
    padding: 6rem 0 8rem;
  }

  .leads-grid {
    display: flex;
    overflow-x: auto;
    gap: 2.5rem;
    padding-bottom: 2rem;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  
  .leads-grid::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }

  .section.leads {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
  
  .lead-card {
    flex: 0 0 300px;
    max-width: 85vw;
    scroll-snap-align: start;
    background: #ffffff;
    border-radius: 28px;
    padding: 1rem;
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.03);
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.03);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lead-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px -10px rgba(0,0,0,0.08);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 4/4.5;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    background: #fdfdfd;
  }

  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) brightness(1.05);
    transform: scale(1.02);
    transition: filter 0.8s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lead-card:hover .card-image-wrapper img {
    filter: grayscale(0%) brightness(1);
    transform: scale(1.05);
  }
  
  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: rgba(0, 0, 0, 0.05);
    font-weight: 300;
    background: #fdfdfd;
    transition: filter 0.8s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lead-card:hover .photo-placeholder {
    transform: scale(1.05);
  }

  .card-info {
    padding: 0 0.5rem 0.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .role-text {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    color: #1a1a1a;
  }

  .role-primary, .role-secondary {
    color: inherit;
  }

  .lead-name {
    font-size: 1.6rem;
    color: #1a1a1a;
    font-weight: 400;
    margin: 0;
    letter-spacing: -0.01em;
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
    transition: color 0.4s ease;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .hero { padding-top: 8rem; }
    .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 4rem; }
    .hero-content { text-align: center; margin: 0 auto; }
    .hero-actions { justify-content: center; }
    .hero-visual { height: 350px; margin-top: 2rem; }
    .card-hackathon { left: 0%; width: 280px; }
    .card-ai { right: 0%; width: 240px; }
    .card-community { left: 25%; width: 200px; }
    .snippet-grid { grid-template-columns: 1fr; gap: 4rem; }
    .snippet-image { order: 2; }
    .snippet-content { order: 1; text-align: center; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero { padding-top: 6rem; padding-bottom: 4rem; }
    .hero-title { font-size: 3.25rem; letter-spacing: -1.5px; }
    .hero-subtitle { font-size: 1.1rem; margin-bottom: 2rem; }
    .hero-visual { display: none; } /* Hide complex overlapping visuals on small mobile screens */
    
    .hero-actions { flex-direction: column; gap: 1rem; width: 100%; }
    .hero-actions .btn { width: 100%; }
    
    .stats-grid { grid-template-columns: 1fr; }
    .img-placeholder { height: 300px; font-size: 1.2rem; }
  }

  /* --- Join CTA Section --- */
  .join-cta {
    padding: 4rem 0 6rem;
  }

  .cta-card {
    max-width: 720px;
    margin: 0 auto;
    background: #ffffff;
    padding: 3.5rem 3rem;
    border-radius: 28px;
    border: 1px solid rgba(0, 0, 0, 0.04);
    box-shadow: 0 20px 60px -10px rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }

  .cta-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 80px -15px rgba(0, 0, 0, 0.08);
  }

  .cta-icon-badge {
    width: 60px;
    height: 60px;
    background: #fdfdfd;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.03);
    animation: cta-float 4s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes cta-float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-4px) scale(1.02); }
  }

  .cta-title-aesthetic {
    font-size: 3rem;
    margin-top: 0;
    margin-bottom: 1rem;
    font-weight: 400;
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
    color: #1a1a1a;
    line-height: 1.1;
    z-index: 1;
  }

  .cta-desc {
    font-size: 1.1rem;
    color: #1a1a1a;
    margin-bottom: 2.25rem;
    line-height: 1.6;
    max-width: 540px;
    z-index: 1;
  }

  .cta-action {
    z-index: 1;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .btn-large {
    padding: 1.1rem 3.5rem;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 0 3rem;
    }
    .hero-outline-wrapper {
      margin: 0.5rem 0 1rem;
    }
    .hero-svg-text-base, .hero-svg-text-racing {
      font-size: 175px;
    }
    .hero-subtitle {
      font-size: 1rem;
      padding: 0 1rem;
    }
    .join-cta {
      padding: 3rem 0 5rem;
    }
    .cta-card {
      padding: 2.5rem 1.75rem;
      border-radius: 20px;
    }
    .cta-card h2 {
      font-size: 2.1rem;
    }
    .cta-desc {
      font-size: 1rem;
      margin-bottom: 1.75rem;
    }
    .btn-large {
      padding: 1rem 2.5rem;
      font-size: 1rem;
      width: 100%;
    }
  }
</style>
