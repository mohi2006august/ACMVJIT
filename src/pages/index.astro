---
import Layout from '../layouts/Layout.astro';
import leadsData from '../data/leads.json';
---

<Layout 
  title="Home" 
  isHome={true}
  description="Welcome to the official ACM VJIT Student Chapter. Join the ultimate CSE(AI&ML) community at Vidya Jyothi Institute of Technology. Explore coding hackathons, technical seminars, open-source projects, and industry networking."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-single" style="position: relative; z-index: 2;">
      <div class="hero-badge"><span class="badge-dot"></span> <span id="typewriter"></span><span class="cursor">|</span></div>
      
      <div class="hero-outline-wrapper" style="margin: 1rem 0 2rem; height: auto;">
        <svg class="hero-svg-title" viewBox="0 0 1000 200" preserveAspectRatio="xMidYMid meet">
          <defs>
            <linearGradient id="sweepGradient" x1="-100%" y1="0%" x2="0%" y2="0%">
              <stop offset="0%" stop-color="rgba(0, 114, 206, 0)" />
              <stop offset="25%" stop-color="#0072CE" /> <!-- dark blue color -->
              <stop offset="85%" stop-color="#00d2ff" /> <!-- light colour -->
              <stop offset="100%" stop-color="rgba(0, 114, 206, 0)" />
              <animate attributeName="x1" values="-100%; 200%" dur="3s" repeatCount="indefinite" />
              <animate attributeName="x2" values="0%; 300%" dur="3s" repeatCount="indefinite" />
            </linearGradient>
          </defs>
          <!-- Faint base outline -->
          <text x="50%" y="55%" text-anchor="middle" dominant-baseline="middle" class="hero-svg-text-base">
            ACM VJIT
          </text>
          <!-- Glowing racing line -->
          <text x="50%" y="55%" text-anchor="middle" dominant-baseline="middle" class="hero-svg-text-racing">
            ACM VJIT
          </text>
        </svg>
      </div>

      <p class="hero-subtitle centered-subtitle">
        ACM brings together students passionate about computing — from algorithms to applications. Through events, mentorship, and a strong community, it creates opportunities to move from concepts to real, working solutions.
      </p>
      
      <div class="hero-actions centered-actions">
        <a href="/recruitment" class="btn btn-primary btn-glow">Join ACM VJIT</a>
        <a href="/events" class="btn btn-outline">Explore Events</a>
      </div>
    </div>
  </section>


  <!-- About Snippet Section -->
  <section class="section about-snippet scroll-reveal">
    <div class="container snippet-grid">
      <div class="snippet-image delay-1">
        <div class="real-image-wrapper">
          <img src="https://res.cloudinary.com/dlz7901m4/image/upload/v1780600879/WhatsApp_Image_2026-06-05_at_00.37.57_qbqzp0.jpg" alt="ACM VJIT Auditorium Event" class="real-image" />
        </div>
      </div>
      <div class="snippet-content delay-2">
        <h2>Cultivating Technical <span class="text-primary">Proficiency</span></h2>
        <p>The ACM VJIT Student Chapter is a dedicated academic and professional organization. We facilitate the transition from theoretical computing principles to applied industry practices. Our initiatives provide members with comprehensive technical skill development, structured mentorship programs, and exposure to cutting-edge research.</p>
        <ul class="check-list">
          <li><span class="check-icon">✅</span> Advanced Technical Workshops</li>
          <li><span class="check-icon">✅</span> Industry Expert Seminars</li>
          <li><span class="check-icon">✅</span> Open Source & Research Initiatives</li>
        </ul>
        <a href="/about" class="btn btn-outline" style="margin-top: 1.5rem;">Read Our Story</a>
      </div>
    </div>
  </section>

  <!-- Institution Leads Section -->
  <section class="section leads scroll-reveal">
    <div class="container">
      <div class="text-center" style="margin-bottom: 4rem;">
        <h2>Institution <span class="text-primary">Leads</span></h2>
        <p style="color: var(--text-muted); font-size: 1.1rem;">Meet the distinguished leadership driving the strategic vision of ACM VJIT.</p>
      </div>
      <div class="leads-grid">
        {
          leadsData.map((lead, index) => {
            const roleParts = lead.role.split(',');
            const primaryRole = roleParts[0];
            const secondaryRole = roleParts.length > 1 ? roleParts[1].trim() : null;
            return (
              <div class={`lead-card delay-${(index % 4) + 1}`}>
                <div class="card-corner"></div>
                <div class="card-badge">
                  <svg viewBox="0 0 24 24" class="badge-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                  <div class="badge-text">
                    <span class="role-primary">{primaryRole}</span>
                    {secondaryRole && <span class="role-secondary">{secondaryRole}</span>}
                  </div>
                </div>
                <div class="card-photo-wrapper">
                  <div class="card-photo-inner">
                    {lead.photo ? (
                      <img src={lead.photo} alt={lead.name} />
                    ) : (
                      <div class="photo-placeholder">{lead.name.charAt(0)}</div>
                    )}
                  </div>
                </div>
                <h3 class="lead-name">{lead.name}</h3>
              </div>
            );
          })
        }
      </div>
      <div class="text-center" style="margin-top: 3.5rem;">
        <a href="/team" class="btn btn-outline">View Full Team</a>
      </div>
    </div>
  </section>

  <!-- Join Us CTA Section -->
  <section class="section join-cta scroll-reveal">
    <div class="container">
      <div class="cta-card">
        <div class="cta-icon-badge">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h2>Ready to <span class="text-gradient-animated">Innovate?</span></h2>
        <p class="cta-desc">Become a member of Vidya Jyothi Institute of Technology's premier computing community. Expand your skills, collaborate on projects, and lead the future of technology.</p>
        <div class="cta-action">
          <a href="/recruitment" class="btn btn-primary btn-glow btn-large">Join Us Now</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  function initHomeJS() {
    // 1. Intersection Observer for scroll animations
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target); 
        }
      });
    }, observerOptions);

    const revealElements = document.querySelectorAll('.scroll-reveal');
    revealElements.forEach(el => observer.observe(el));

    // 2. Typewriter Effect for Hero Tagline
    const words = [
      "From algorithms to applications.",
      "Where curiosity meets computing.",
      "Learn. Build. Compute.",
      "Turning ideas into working solutions.",
      "Code with purpose.",
      "Computing, powered by community."
    ];
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    const typedTextSpan = document.getElementById("typewriter");
    
    if(typedTextSpan) {
      typedTextSpan.textContent = "";

      function typeSubtitle() {
        if(!typedTextSpan) return;
        const currentWord = words[wordIndex];
        if (isDeleting) {
          typedTextSpan.textContent = currentWord.substring(0, charIndex - 1);
          charIndex--;
        } else {
          typedTextSpan.textContent = currentWord.substring(0, charIndex + 1);
          charIndex++;
        }
        
        let typeSpeed = isDeleting ? 20 : 60;
        
        if (!isDeleting && charIndex === currentWord.length) {
          typeSpeed = 2500;
          isDeleting = true;
        } else if (isDeleting && charIndex === 0) {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          typeSpeed = 500;
        }
        
        setTimeout(typeSubtitle, typeSpeed);
      }
      setTimeout(typeSubtitle, 1000);
    }

  }

  document.addEventListener('DOMContentLoaded', initHomeJS);
  document.addEventListener('astro:page-load', initHomeJS);
</script>

<style>
  /* --- Hero Section (Centered Layout) --- */
  .hero {
    padding: 8rem 0 6rem;
    position: relative;
    overflow: hidden;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: calc(100vh - 80px); /* 80px for header approx */
    justify-content: center;
  }

  .hero-single {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
    perspective: 1200px;
  }
  
  .centered-subtitle {
    margin: 0 auto 2rem auto;
    text-align: center;
  }
  
  .centered-actions {
    justify-content: center;
  }

  .hero-content {
    text-align: left;
    position: relative;
    z-index: 2;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.5rem;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--primary-color);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 2rem;
    border: 1px solid rgba(0, 114, 206, 0.2);
    box-shadow: 0 10px 25px rgba(0, 114, 206, 0.08), inset 0 0 10px rgba(255, 255, 255, 0.5);
    opacity: 0;
    transform-origin: center bottom;
    animation: cinematicEnter 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.1s;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background-color: #00d2ff;
    border-radius: 50%;
    display: inline-block;
    margin-right: 0.7rem;
    box-shadow: 0 0 12px rgba(0, 210, 255, 0.9);
    animation: badge-pulse 1.8s infinite alternate;
  }

  @keyframes badge-pulse {
    0% { transform: scale(0.8); opacity: 0.5; }
    100% { transform: scale(1.2); opacity: 1; }
  }

  .cursor {
    display: inline-block;
    width: 2px;
    background-color: var(--primary-color);
    margin-left: 2px;
    animation: blink 1s infinite;
    vertical-align: middle;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-subtitle, .hero-actions {
    opacity: 0;
    transform-origin: center bottom;
    animation: cinematicEnter 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    margin-bottom: 2rem;
    color: #475569;
    font-weight: 500;
    animation-delay: 0.5s;
    line-height: 1.8;
    max-width: 680px;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
  }

  .hero-actions {
    display: flex;
    justify-content: flex-start;
    gap: 1.5rem;
    animation-delay: 0.7s;
    flex-wrap: wrap;
  }

  .hero-actions .btn {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: 999px;
    box-shadow: 0 8px 25px rgba(0, 114, 206, 0.2);
  }

  /* --- SVG Line Drawing Text Effect --- */
  .hero-outline-wrapper {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    opacity: 0;
    transform-origin: center bottom;
    animation: cinematicEnter 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.3s;
  }

  .hero-svg-title {
    width: 100%;
    max-width: 1000px;
    height: auto;
    overflow: visible;
  }

  .hero-svg-text-base, .hero-svg-text-racing {
    font-size: 165px;
    font-weight: 900;
    font-family: 'Segoe UI Black', 'Arial Black', sans-serif;
    fill: transparent;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-svg-text-base {
    stroke: var(--primary-color);
    stroke-width: 3px;
    filter: drop-shadow(0 0 20px rgba(255, 255, 255, 1));
  }

  .hero-svg-text-racing {
    stroke: url(#sweepGradient);
    stroke-width: 2.5px;
    animation: svg-glow 2s infinite alternate;
  }

  @keyframes svg-glow {
    from {
      filter: drop-shadow(0 4px 10px rgba(0, 114, 206, 0.2));
    }
    to {
      filter: drop-shadow(0 10px 25px rgba(0, 114, 206, 0.4));
    }
  }

  @keyframes cinematicEnter {
    0% { 
      opacity: 0; 
      transform: translateY(80px) rotateX(-20deg) scale(0.9); 
      filter: blur(10px); 
    }
    100% { 
      opacity: 1; 
      transform: translateY(0) rotateX(0deg) scale(1); 
      filter: blur(0px); 
    }
  }

  @keyframes fadeUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .btn-glow {
    position: relative;
    overflow: hidden;
  }
  
  .btn-glow::after {
    content: '';
    position: absolute;
    top: -50%; left: -50%; width: 200%; height: 200%;
    background: rgba(255,255,255,0.3);
    transform: rotate(45deg) translate(-50%, -50%);
    animation: button-shine 3s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes button-shine {
    0% { transform: translateX(-150%) rotate(45deg); }
    30%, 100% { transform: translateX(150%) rotate(45deg); }
  }

  /* --- Scroll Animations Base --- */
  .scroll-reveal > *, .scroll-reveal .feature-card, .scroll-reveal .stat-card, .scroll-reveal .snippet-image, .scroll-reveal .snippet-content, .scroll-reveal .cta-box {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-reveal.in-view > *, .scroll-reveal.in-view .feature-card, .scroll-reveal.in-view .stat-card, .scroll-reveal.in-view .snippet-image, .scroll-reveal.in-view .snippet-content, .scroll-reveal.in-view .cta-box {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-1 { transition-delay: 0.1s !important; }
  .delay-2 { transition-delay: 0.25s !important; }
  .delay-3 { transition-delay: 0.4s !important; }
  .delay-4 { transition-delay: 0.55s !important; }



  /* --- About Snippet Section --- */
  .about-snippet {
    background: linear-gradient(to bottom, transparent, rgba(0, 114, 206, 0.02), transparent);
    padding: 8rem 0;
  }

  .snippet-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .real-image-wrapper {
    width: 100%;
    height: 450px;
    position: relative;
    border-radius: 24px;
    transition: transform 0.5s ease;
  }
  
  .real-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: 0 15px 40px rgba(0, 114, 206, 0.15);
    border: 1px solid rgba(0, 114, 206, 0.1);
  }

  .snippet-image:hover .real-image-wrapper {
    transform: rotate(1deg) scale(1.02);
  }

  .real-image-wrapper::after {
    content: '';
    position: absolute;
    inset: -15px;
    border: 2px dashed rgba(0, 114, 206, 0.2);
    border-radius: 32px;
    z-index: -1;
    transition: all 0.5s ease;
  }
  
  .snippet-image:hover .real-image-wrapper::after {
    transform: rotate(-2deg);
    border-color: rgba(0, 114, 206, 0.4);
  }

  .check-list {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-weight: 500;
  }
  
  .check-icon {
    margin-right: 0.5rem;
    display: inline-block;
  }

  /* --- Leads Section --- */
  .leads {
    padding: 6rem 0 8rem;
  }

  .leads-grid {
    display: flex;
    overflow-x: auto;
    gap: 2.5rem;
    padding-bottom: 2rem;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  
  .leads-grid::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }

  .section.leads {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
  
  .lead-card {
    flex: 0 0 320px;
    max-width: 85vw;
    scroll-snap-align: start;
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  
  .lead-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 114, 206, 0.12);
  }

  .card-corner {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    width: 25px;
    height: 25px;
    border-top: 2px solid rgba(0, 114, 206, 0.3);
    border-left: 2px solid rgba(0, 114, 206, 0.3);
  }

  .card-badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.05) 0%, rgba(0, 210, 255, 0.1) 100%);
    border: 1px solid rgba(0, 114, 206, 0.2);
    padding: 0.4rem 1rem 0.4rem 0.6rem;
    border-radius: 50px;
    margin-left: 1.2rem; 
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    z-index: 2;
  }

  .badge-icon {
    width: 18px;
    height: 18px;
    color: var(--primary-color);
  }

  .badge-text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .role-primary {
    font-size: 0.7rem;
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: 1px;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .role-secondary {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--primary-color);
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 1.2;
    margin-top: 0.1rem;
  }

  .card-photo-wrapper {
    width: 100%;
    aspect-ratio: 4/4.5;
    margin-bottom: 1.5rem;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .card-photo-inner {
    width: 90%;
    height: 95%;
    border-radius: 30px 30px 10px 40px; 
    overflow: hidden;
    transform: rotate(2deg);
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.05) 0%, rgba(0, 210, 255, 0.1) 100%);
    box-shadow: 0 10px 20px rgba(0, 114, 206, 0.08);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .lead-card:hover .card-photo-inner {
    transform: rotate(0deg) scale(1.02);
    box-shadow: 0 15px 30px rgba(0, 114, 206, 0.15);
  }

  .card-photo-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: rotate(-2deg) scale(1.05); 
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: rgba(0, 114, 206, 0.15);
    font-weight: bold;
    transform: rotate(-2deg);
  }

  .lead-name {
    font-size: 1.35rem;
    color: #1a1a1a;
    margin-top: auto;
    font-weight: 700;
    text-align: left;
    padding-left: 0.5rem;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .hero { padding-top: 8rem; }
    .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 4rem; }
    .hero-content { text-align: center; margin: 0 auto; }
    .hero-actions { justify-content: center; }
    .hero-visual { height: 350px; margin-top: 2rem; }
    .card-hackathon { left: 0%; width: 280px; }
    .card-ai { right: 0%; width: 240px; }
    .card-community { left: 25%; width: 200px; }
    .snippet-grid { grid-template-columns: 1fr; gap: 4rem; }
    .snippet-image { order: 2; }
    .snippet-content { order: 1; text-align: center; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero { padding-top: 6rem; padding-bottom: 4rem; }
    .hero-title { font-size: 3.25rem; letter-spacing: -1.5px; }
    .hero-subtitle { font-size: 1.1rem; margin-bottom: 2rem; }
    .hero-visual { display: none; } /* Hide complex overlapping visuals on small mobile screens */
    
    .hero-actions { flex-direction: column; gap: 1rem; width: 100%; }
    .hero-actions .btn { width: 100%; }
    
    .stats-grid { grid-template-columns: 1fr; }
    .img-placeholder { height: 300px; font-size: 1.2rem; }
  }

  /* --- Join CTA Section --- */
  .join-cta {
    padding: 4rem 0 6rem;
  }

  .cta-card {
    max-width: 720px;
    margin: 0 auto;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.7) 0%, rgba(0, 114, 206, 0.03) 50%, rgba(255, 255, 255, 0.45) 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 3.5rem 3rem;
    border-radius: 28px;
    border: 1px solid rgba(0, 114, 206, 0.15);
    box-shadow: 0 30px 60px rgba(0, 114, 206, 0.06), inset 0 0 20px rgba(255, 255, 255, 0.6);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .cta-card:hover {
    transform: translateY(-6px);
    border-color: rgba(0, 114, 206, 0.3);
    box-shadow: 0 40px 80px rgba(0, 114, 206, 0.12), inset 0 0 20px rgba(255, 255, 255, 0.7);
  }

  /* Decorative glowing orb background */
  .cta-card::after {
    content: '';
    position: absolute;
    top: -50px;
    right: -50px;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(0, 210, 255, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
    filter: blur(20px);
    pointer-events: none;
    z-index: 0;
  }

  .cta-icon-badge {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.08) 0%, rgba(0, 210, 255, 0.12) 100%);
    border: 1px solid rgba(0, 114, 206, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
