---
import Layout from '../layouts/Layout.astro';
import leadsData from '../data/leads.json';
---

<Layout 
  title="Home" 
  isHome={true}
  description="Welcome to the official ACM VJIT Student Chapter. Join the ultimate CSE(AI&ML) community at Vidya Jyothi Institute of Technology. Explore coding hackathons, technical seminars, open-source projects, and industry networking."
>
    <!-- Hero Section (Centered Layout) -->
    <section class="hero">
      <div class="container hero-grid">
        <!-- Centered Hero Text Content -->
        <div class="hero-content">
          <div class="hero-glow-orb"></div>
          <div class="hero-badge"><span class="badge-dot"></span> Advancing Computing Machinery & Research</div>
          <h1 class="hero-title"><span class="hero-welcome">Welcome to</span><br/><span class="text-gradient-animated">ACM VJIT</span></h1>
          <p class="hero-subtitle">
            Empowering the next generation to <span class="text-primary font-bold" id="typewriter">Innovate</span><span class="cursor">|</span>
            <br/><span class="subtitle-desc">The official ACM Student Chapter at Vidya Jyothi Institute of Technology.</span>
          </p>
          <div class="hero-actions">
            <a href="/events" class="btn btn-primary btn-glow">Upcoming Events</a>
            <a href="/about" class="btn btn-outline">Learn More</a>
          </div>
        </div>
      </div>
    </section>


  <!-- About Snippet Section -->
  <section class="section about-snippet scroll-reveal">
    <div class="container snippet-grid">
      <div class="snippet-image delay-1">
        <div class="real-image-wrapper">
          <img src="https://res.cloudinary.com/dlz7901m4/image/upload/v1780600879/WhatsApp_Image_2026-06-05_at_00.37.57_qbqzp0.jpg" alt="ACM VJIT Auditorium Event" class="real-image" />
        </div>
      </div>
      <div class="snippet-content delay-2">
        <h2>Cultivating Technical <span class="text-primary">Proficiency</span></h2>
        <p>The ACM VJIT Student Chapter is a dedicated academic and professional organization. We facilitate the transition from theoretical computing principles to applied industry practices. Our initiatives provide members with comprehensive technical skill development, structured mentorship programs, and exposure to cutting-edge research.</p>
        <ul class="check-list">
          <li><span class="check-icon">✅</span> Advanced Technical Workshops</li>
          <li><span class="check-icon">✅</span> Industry Expert Seminars</li>
          <li><span class="check-icon">✅</span> Open Source & Research Initiatives</li>
        </ul>
        <a href="/about" class="btn btn-outline" style="margin-top: 1.5rem;">Read Our Story</a>
      </div>
    </div>
  </section>

  <!-- Institution Leads Section -->
  <section class="section leads scroll-reveal">
    <div class="container">
      <div class="text-center" style="margin-bottom: 4rem;">
        <h2>Institution <span class="text-primary">Leads</span></h2>
        <p style="color: var(--text-muted); font-size: 1.1rem;">Meet the distinguished leadership driving the strategic vision of ACM VJIT.</p>
      </div>
      <div class="leads-grid">
        {
          leadsData.map((lead, index) => {
            const roleParts = lead.role.split(',');
            const primaryRole = roleParts[0];
            const secondaryRole = roleParts.length > 1 ? roleParts[1].trim() : null;
            return (
              <div class={`lead-card delay-${(index % 4) + 1}`}>
                <div class="card-corner"></div>
                <div class="card-badge">
                  <svg viewBox="0 0 24 24" class="badge-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                  <div class="badge-text">
                    <span class="role-primary">{primaryRole}</span>
                    {secondaryRole && <span class="role-secondary">{secondaryRole}</span>}
                  </div>
                </div>
                <div class="card-photo-wrapper">
                  <div class="card-photo-inner">
                    {lead.photo ? (
                      <img src={lead.photo} alt={lead.name} />
                    ) : (
                      <div class="photo-placeholder">{lead.name.charAt(0)}</div>
                    )}
                  </div>
                </div>
                <h3 class="lead-name">{lead.name}</h3>
              </div>
            );
          })
        }
      </div>
      <div class="text-center" style="margin-top: 3.5rem;">
        <a href="/team" class="btn btn-outline">View Full Team</a>
      </div>
    </div>
  </section>

  <!-- Join Us CTA Section -->
  <section class="section join-cta scroll-reveal">
    <div class="container">
      <div class="cta-card">
        <div class="cta-icon-badge">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h2>Ready to <span class="text-gradient-animated">Innovate?</span></h2>
        <p class="cta-desc">Become a member of Vidya Jyothi Institute of Technology's premier computing community. Expand your skills, collaborate on projects, and lead the future of technology.</p>
        <div class="cta-action">
          <a href="/recruitment" class="btn btn-primary btn-glow btn-large">Join Us Now</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  function initHomeJS() {
    // 1. Intersection Observer for scroll animations
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target); 
        }
      });
    }, observerOptions);

    const revealElements = document.querySelectorAll('.scroll-reveal');
    revealElements.forEach(el => observer.observe(el));

    // 2. Typewriter Effect for Hero Subtitle
    const words = ["Innovate", "Collaborate", "Build", "Lead", "Code"];
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    const typedTextSpan = document.getElementById("typewriter");
    
    if(typedTextSpan) {
      typedTextSpan.textContent = "";

      function typeSubtitle() {
        if(!typedTextSpan) return;
        const currentWord = words[wordIndex];
        if (isDeleting) {
          typedTextSpan.textContent = currentWord.substring(0, charIndex - 1);
          charIndex--;
        } else {
          typedTextSpan.textContent = currentWord.substring(0, charIndex + 1);
          charIndex++;
        }
        
        let typeSpeed = isDeleting ? 40 : 80;
        
        if (!isDeleting && charIndex === currentWord.length) {
          typeSpeed = 2000;
          isDeleting = true;
        } else if (isDeleting && charIndex === 0) {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          typeSpeed = 500;
        }
        
        setTimeout(typeSubtitle, typeSpeed);
      }
      setTimeout(typeSubtitle, 1000);
    }

    // Terminal script removed
  }

  document.addEventListener('DOMContentLoaded', initHomeJS);
  document.addEventListener('astro:page-load', initHomeJS);
</script>

<style>
  /* --- Hero Section (2-Column) --- */
  .hero {
    padding: 8rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  .hero-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero-content {
    text-align: center;
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-glow-orb {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 114, 206, 0.1) 0%, rgba(0, 210, 255, 0.04) 50%, rgba(255, 255, 255, 0) 70%);
    filter: blur(75px);
    pointer-events: none;
    z-index: -1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    background: rgba(0, 114, 206, 0.05);
    color: var(--primary-color);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 2rem;
    border: 1px solid rgba(0, 114, 206, 0.15);
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    background-color: var(--primary-color);
    border-radius: 50%;
    display: inline-block;
    margin-right: 0.6rem;
    box-shadow: 0 0 10px rgba(0, 114, 206, 0.8);
    animation: badge-pulse 1.8s infinite alternate;
  }

  @keyframes badge-pulse {
    0% { transform: scale(0.8); opacity: 0.5; }
    100% { transform: scale(1.2); opacity: 1; }
  }

  .hero-welcome {
    font-size: 2rem;
    font-weight: 600;
    color: #64748b; /* Slate 500 */
    letter-spacing: 2px;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 0.4rem;
  }

  .hero-title, .hero-subtitle, .hero-actions {
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-title {
    font-size: 5.5rem;
    font-weight: 900;
    margin-bottom: 1.5rem;
    letter-spacing: -3px;
    animation-delay: 0.2s;
    line-height: 1.05;
    color: #0f172a;
  }

  .text-gradient-animated {
    background: linear-gradient(to right, #0072CE, #00d2ff, #8b5cf6, #0072CE);
    background-size: 300% auto;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    animation: gradient-shift 5s linear infinite;
  }

  @keyframes gradient-shift {
    to { background-position: 200% center; }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    margin-bottom: 3rem;
    color: var(--text-muted);
    animation-delay: 0.4s;
    line-height: 1.6;
  }

  .subtitle-desc {
    font-size: 1.1rem;
    opacity: 0.8;
  }
  
  .font-bold {
    font-weight: 700;
  }

  .cursor {
    display: inline-block;
    width: 3px;
    background-color: var(--primary-color);
    color: transparent;
    animation: blink 1s step-end infinite;
    vertical-align: text-bottom;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    animation-delay: 0.6s;
  }

  @keyframes fadeUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .btn-glow {
    position: relative;
    overflow: hidden;
  }
  
  .btn-glow::after {
    content: '';
    position: absolute;
    top: -50%; left: -50%; width: 200%; height: 200%;
    background: rgba(255,255,255,0.3);
    transform: rotate(45deg) translate(-50%, -50%);
    animation: button-shine 3s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes button-shine {
    0% { transform: translateX(-150%) rotate(45deg); }
    30%, 100% { transform: translateX(150%) rotate(45deg); }
  }

  /* --- Scroll Animations Base --- */
  .scroll-reveal > *, .scroll-reveal .feature-card, .scroll-reveal .stat-card, .scroll-reveal .snippet-image, .scroll-reveal .snippet-content, .scroll-reveal .cta-box {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-reveal.in-view > *, .scroll-reveal.in-view .feature-card, .scroll-reveal.in-view .stat-card, .scroll-reveal.in-view .snippet-image, .scroll-reveal.in-view .snippet-content, .scroll-reveal.in-view .cta-box {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-1 { transition-delay: 0.1s !important; }
  .delay-2 { transition-delay: 0.25s !important; }
  .delay-3 { transition-delay: 0.4s !important; }
  .delay-4 { transition-delay: 0.55s !important; }



  /* --- About Snippet Section --- */
  .about-snippet {
    background: linear-gradient(to bottom, transparent, rgba(0, 114, 206, 0.02), transparent);
    padding: 8rem 0;
  }

  .snippet-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .real-image-wrapper {
    width: 100%;
    height: 450px;
    position: relative;
    border-radius: 24px;
    transition: transform 0.5s ease;
  }
  
  .real-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: 0 15px 40px rgba(0, 114, 206, 0.15);
    border: 1px solid rgba(0, 114, 206, 0.1);
  }

  .snippet-image:hover .real-image-wrapper {
    transform: rotate(1deg) scale(1.02);
  }

  .real-image-wrapper::after {
    content: '';
    position: absolute;
    inset: -15px;
    border: 2px dashed rgba(0, 114, 206, 0.2);
    border-radius: 32px;
    z-index: -1;
    transition: all 0.5s ease;
  }
  
  .snippet-image:hover .real-image-wrapper::after {
    transform: rotate(-2deg);
    border-color: rgba(0, 114, 206, 0.4);
  }

  .check-list {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-weight: 500;
  }
  
  .check-icon {
    margin-right: 0.5rem;
    display: inline-block;
  }

  /* --- Leads Section --- */
  .leads {
    padding: 6rem 0 8rem;
  }

  .leads-grid {
    display: flex;
    overflow-x: auto;
    gap: 2.5rem;
    padding-bottom: 2rem;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  
  .leads-grid::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }

  .section.leads {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
  
  .lead-card {
    flex: 0 0 320px;
    max-width: 85vw;
    scroll-snap-align: start;
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  
  .lead-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 114, 206, 0.12);
  }

  .card-corner {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    width: 25px;
    height: 25px;
    border-top: 2px solid rgba(0, 114, 206, 0.3);
    border-left: 2px solid rgba(0, 114, 206, 0.3);
  }

  .card-badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.05) 0%, rgba(0, 210, 255, 0.1) 100%);
    border: 1px solid rgba(0, 114, 206, 0.2);
    padding: 0.4rem 1rem 0.4rem 0.6rem;
    border-radius: 50px;
    margin-left: 1.2rem; 
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    z-index: 2;
  }

  .badge-icon {
    width: 18px;
    height: 18px;
    color: var(--primary-color);
  }

  .badge-text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .role-primary {
    font-size: 0.7rem;
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: 1px;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .role-secondary {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--primary-color);
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 1.2;
    margin-top: 0.1rem;
  }

  .card-photo-wrapper {
    width: 100%;
    aspect-ratio: 4/4.5;
    margin-bottom: 1.5rem;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .card-photo-inner {
    width: 90%;
    height: 95%;
    border-radius: 30px 30px 10px 40px; 
    overflow: hidden;
    transform: rotate(2deg);
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.05) 0%, rgba(0, 210, 255, 0.1) 100%);
    box-shadow: 0 10px 20px rgba(0, 114, 206, 0.08);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .lead-card:hover .card-photo-inner {
    transform: rotate(0deg) scale(1.02);
    box-shadow: 0 15px 30px rgba(0, 114, 206, 0.15);
  }

  .card-photo-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: rotate(-2deg) scale(1.05); 
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    color: rgba(0, 114, 206, 0.15);
    font-weight: bold;
    transform: rotate(-2deg);
  }

  .lead-name {
    font-size: 1.35rem;
    color: #1a1a1a;
    margin-top: auto;
    font-weight: 700;
    text-align: left;
    padding-left: 0.5rem;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .hero { padding-top: 6rem; }
    .snippet-grid { grid-template-columns: 1fr; gap: 4rem; }
    .snippet-image { order: 2; }
    .snippet-content { order: 1; text-align: center; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero { padding-top: 5rem; padding-bottom: 3rem; }
    .hero-welcome { font-size: 1.35rem; letter-spacing: 1px; }
    .hero-title { font-size: 3.25rem; letter-spacing: -1.5px; }
    .hero-subtitle { font-size: 1.1rem; margin-bottom: 2rem; }
    
    .hero-actions { flex-direction: column; gap: 1rem; width: 100%; }
    .hero-actions .btn { width: 100%; }
    
    .stats-grid { grid-template-columns: 1fr; }
    .img-placeholder { height: 300px; font-size: 1.2rem; }
  }

  /* --- Join CTA Section --- */
  .join-cta {
    padding: 4rem 0 6rem;
  }

  .cta-card {
    max-width: 720px;
    margin: 0 auto;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.7) 0%, rgba(0, 114, 206, 0.03) 50%, rgba(255, 255, 255, 0.45) 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 3.5rem 3rem;
    border-radius: 28px;
    border: 1px solid rgba(0, 114, 206, 0.15);
    box-shadow: 0 30px 60px rgba(0, 114, 206, 0.06), inset 0 0 20px rgba(255, 255, 255, 0.6);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .cta-card:hover {
    transform: translateY(-6px);
    border-color: rgba(0, 114, 206, 0.3);
    box-shadow: 0 40px 80px rgba(0, 114, 206, 0.12), inset 0 0 20px rgba(255, 255, 255, 0.7);
  }

  /* Decorative glowing orb background */
  .cta-card::after {
    content: '';
    position: absolute;
    top: -50px;
    right: -50px;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(0, 210, 255, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
    filter: blur(20px);
    pointer-events: none;
    z-index: 0;
  }

  .cta-icon-badge {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, rgba(0, 114, 206, 0.08) 0%, rgba(0, 210, 255, 0.12) 100%);
    border: 1px solid rgba(0, 114, 206, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-color);
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 25px rgba(0, 114, 206, 0.05);
    animation: cta-float 4s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes cta-float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-6px) scale(1.05); }
  }

  .cta-card h2 {
    font-size: 2.75rem;
    margin-top: 0;
    margin-bottom: 1rem;
    font-weight: 800;
    line-height: 1.2;
    z-index: 1;
  }

  .cta-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 2.25rem;
    line-height: 1.6;
    max-width: 540px;
    z-index: 1;
  }

  .cta-action {
    z-index: 1;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .btn-large {
    padding: 1.1rem 3.5rem;
    font-size: 1.1rem;
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 768px) {
    .join-cta {
      padding: 3rem 0 5rem;
    }
    .cta-card {
      padding: 2.5rem 1.75rem;
      border-radius: 20px;
    }
    .cta-card h2 {
      font-size: 2.1rem;
    }
    .cta-desc {
      font-size: 1rem;
      margin-bottom: 1.75rem;
    }
    .btn-large {
      padding: 1rem 2.5rem;
      font-size: 1rem;
      width: 100%;
    }
  }
</style>
