---
import Layout from '../layouts/Layout.astro';
import galleryData from '../data/gallery.json';
---

<Layout 
  title="Gallery"
  description="Explore the photo gallery of ACM VJIT. See our students in action during hackathons, tech workshops, coding competitions, and community events."
>
  <div class="gallery-container" id="gallery-container">

    
    <!-- Top Information -->
    <div class="gallery-info text-center animate-fade-up">
      <h1 class="text-4xl md:text-5xl font-bold" style="color: #1a1a1a;">Event <span class="text-primary">Gallery</span></h1>
      <p class="text-muted mt-2" style="text-transform: uppercase; letter-spacing: 2px; font-weight: 700; color: #555;">Drag or swipe to explore our legacy</p>
    </div>
    
    <!-- 3D Scene Wrapper -->
    <div class="scene" id="scene">
      <div class="carousel" id="carousel">
        {galleryData.map((photo, index) => (
          <div class="carousel-item" style={`--index: ${index};`}>
            <div class="image-wrapper">
              <img src={photo.url} alt={photo.caption} loading="lazy" draggable="false" />
              <div class="glass-overlay"></div>
            </div>
            <!-- Floating 3D Caption -->
            <div class="caption">
               <span class="caption-text">{photo.caption}</span>
               <div class="caption-glow"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  function initUltimateGallery() {
    let width = window.innerWidth;
    let height = window.innerHeight;
    
    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
    });

    // --- 2. 3D Carousel Engine ---
    const container = document.getElementById('gallery-container');
    const scene = document.getElementById('scene');
    const carousel = document.getElementById('carousel');
    const items = document.querySelectorAll('.carousel-item');
    if (!carousel) return;

    let currAngle = 0;
    let targetAngle = 0;
    let isDragging = false;
    let startX = 0;
    let autoRotate = true;
    
    // Parallax Mouse tracking
    let mouseX = 0;
    let mouseY = 0;
    let targetMouseX = 0;
    let targetMouseY = 0;

    // We can use the same mouse coordinates for the wave and the carousel
    window.addEventListener('mousemove', (e) => {
      // For Carousel Parallax (-1 to 1)
      targetMouseX = (e.clientX / width - 0.5) * 2; 
      targetMouseY = (e.clientY / height - 0.5) * 2;

      if (!isDragging) return;
      const dx = e.clientX - startX;
      targetAngle += dx * 0.25; 
      startX = e.clientX;
    });

    container.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      autoRotate = false;
      document.body.style.cursor = 'grabbing';
    });

    window.addEventListener('mouseup', () => {
      if(isDragging) {
        isDragging = false;
        document.body.style.cursor = 'default';
        targetAngle = Math.round(targetAngle / 24) * 24;
        setTimeout(() => autoRotate = true, 4000);
      }
    });

    // Touch events
    container.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
      autoRotate = false;
    });
    container.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const dx = e.touches[0].clientX - startX;
      targetAngle += dx * 0.35;
      startX = e.touches[0].clientX;
    });
    container.addEventListener('touchend', () => {
      if(isDragging) {
        isDragging = false;
        targetAngle = Math.round(targetAngle / 24) * 24;
        setTimeout(() => autoRotate = true, 4000);
      }
    });

    container.addEventListener('wheel', (e) => {
      targetAngle += e.deltaY * 0.08;
      autoRotate = false;
      clearTimeout(window.wheelTimeout);
      window.wheelTimeout = setTimeout(() => {
        targetAngle = Math.round(targetAngle / 24) * 24;
        autoRotate = true;
      }, 1500);
    });

    let animationId;
    function animate() {

      // --- Carousel Math ---
      if (autoRotate && !isDragging) targetAngle -= 0.04; 
      currAngle += (targetAngle - currAngle) * 0.08;
      
      mouseX += (targetMouseX - mouseX) * 0.05;
      mouseY += (targetMouseY - mouseY) * 0.05;
      
      scene.style.transform = `rotateX(${-mouseY * 8}deg) rotateY(${mouseX * 12}deg)`;
      carousel.style.transform = `translateZ(-800px) rotateX(-5deg) rotateY(${currAngle}deg)`;
      
      let normalizedAngle = (currAngle % 360 + 360) % 360;
      let activeIndex = Math.round((360 - normalizedAngle) / 24) % 15;
      
      items.forEach((item, index) => {
        if (index === activeIndex) {
          item.classList.add('active');
        } else {
          item.classList.remove('active');
        }
      });
      
      animationId = requestAnimationFrame(animate);
    }
    animate();
    
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', resize);
    }, { once: true });
  }

  document.addEventListener('DOMContentLoaded', initUltimateGallery);
  document.addEventListener('astro:page-load', initUltimateGallery);
</script>

<style>
  .gallery-container {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-info {
    position: absolute;
    top: 10vh;
    z-index: 10;
    pointer-events: none;
  }

  .gallery-info h1 { 
    font-size: 4rem; 
    font-weight: 900; 
    letter-spacing: -1px; 
    text-transform: uppercase;
  }
  @media (max-width: 768px) { .gallery-info h1 { font-size: 2.5rem; } }

  .scene {
    width: 100vw;
    height: 100vh;
    perspective: 1200px; 
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    z-index: 5;
    will-change: transform;
  }

  .carousel {
    width: 380px;
    height: 260px;
    position: relative;
    transform-style: preserve-3d;
    will-change: transform; 
  }

  .carousel-item {
    position: absolute;
    width: 100%;
    height: 100%;
    left: 0;
    top: 0;
    border-radius: 16px;
    transform-style: preserve-3d; 
    transform: rotateY(calc(var(--index) * 24deg)) translateZ(850px);
    transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: filter, transform;
  }

  @media (min-width: 768px) {
    .carousel-item {
      -webkit-box-reflect: below 20px linear-gradient(transparent 20%, transparent 60%, rgba(255,255,255,0.6));
    }
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.05);
    background: #fff;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .carousel-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    opacity: 0.6;
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .glass-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 100%);
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  .carousel-item .caption {
    position: absolute;
    bottom: -60px;
    left: 50%;
    transform: translateX(-50%) translateZ(60px); 
    color: #ffffff;
    font-weight: 800;
    font-size: 1.05rem;
    text-align: center;
    opacity: 0;
    transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .caption-text {
    position: relative;
    z-index: 2;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(12px);
    padding: 0.6rem 1.8rem;
    border-radius: 99px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15), 0 0 20px rgba(0, 114, 206, 0.2);
    border: 1px solid rgba(255,255,255,0.15);
    display: inline-block;
    color: #ffffff;
  }

  .caption-text::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    background: #00d2ff;
    border-radius: 50%;
    margin-right: 12px;
    box-shadow: 0 0 10px #00d2ff;
    vertical-align: middle;
    transform: translateY(-2px);
  }

  /* --- ACTIVE STATE MAGIC --- */
  .carousel-item.active {
    transform: rotateY(calc(var(--index) * 24deg)) translateZ(920px) scale(1.15); 
  }

  .carousel-item.active .image-wrapper {
    border: 3px solid #0072CE;
    box-shadow: 0 20px 50px rgba(0, 114, 206, 0.25), inset 0 0 20px rgba(0, 114, 206, 0.1);
  }

  .carousel-item.active img {
    opacity: 1;
    transform: scale(1.05); 
  }

  .carousel-item.active .caption {
    opacity: 1;
    bottom: -40px;
    transform: translateX(-50%) translateZ(80px); 
  }

  /* Dim non-active items heavily */
  .carousel-item:not(.active) {
    filter: saturate(0.5); /* Less heavy filter for mobile */
    opacity: 0.6;
  }

  @media (min-width: 768px) {
    .carousel-item:not(.active) {
      filter: saturate(0.2) blur(2px);
    }
  }

  .animate-fade-up {
    animation: fadeUp 1s ease forwards;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .carousel {
      width: 260px;
      height: 180px;
    }
    .carousel-item {
      transform: rotateY(calc(var(--index) * 24deg)) translateZ(650px);
    }
    .carousel-item.active {
      transform: rotateY(calc(var(--index) * 24deg)) translateZ(720px) scale(1.1);
    }
  }
</style>
