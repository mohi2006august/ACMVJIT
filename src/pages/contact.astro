---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">

  <div class="relative-z">
    <div class="page-header">
      <div class="container text-center animate-fade-up">
        <h1 style="color: #1a1a1a;">Get In <span class="text-primary">Touch</span></h1>
        <p>Have a question or want to collaborate? We'd love to hear from you.</p>
      </div>
    </div>

    <section class="section animate-fade-up" style="animation-delay: 0.1s;">
    <div class="container contact-container">
      <div class="contact-info">
        <h2>Contact Information</h2>
        <p>Reach out to us through any of the following channels or visit us on campus.</p>
        
        <div class="info-item">
          <div class="icon">✉️</div>
          <div>
            <h4>Email</h4>
            <p>acm@vjit.ac.in</p>
          </div>
        </div>
        
        <div class="info-item">
          <div class="icon">📱</div>
          <div>
            <h4>Social Media</h4>
            <p>Follow us on <a href="#" class="text-primary">Instagram</a> and <a href="#" class="text-primary">LinkedIn</a></p>
          </div>
        </div>

        <div class="info-item" style="margin-bottom: 0.5rem; margin-top: 1.5rem;">
          <div class="icon">📍</div>
          <div style="display: flex; align-items: center;">
            <h4 style="margin: 0;">Address</h4>
          </div>
        </div>

        <div class="map-container animate-fade-up" style="animation-delay: 0.3s; margin-top: 0.5rem;">
          <iframe 
            src="https://maps.google.com/maps?q=Vidya%20Jyothi%20Institute%20of%20Technology%2C%20Hyderabad&t=&z=14&ie=UTF8&iwloc=&output=embed" 
            width="100%" 
            height="250" 
            style="border:0; border-radius: 16px; box-shadow: 0 4px 30px rgba(0, 114, 206, 0.05); border: 1px solid rgba(0, 114, 206, 0.1);" 
            allowfullscreen="" 
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>
      
      <div class="contact-form">
        <form id="contact-form">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" required placeholder="John Doe">
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" required placeholder="john@example.com">
          </div>
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" required placeholder="+91 9876543210">
          </div>
          <div class="form-group" style="display: flex; gap: 1rem;">
            <div style="flex: 1;">
              <label for="department">Department</label>
              <input type="text" id="department" required placeholder="e.g. CSE (AI&ML)">
            </div>
            <div style="flex: 1;">
              <label for="year">Year</label>
              <input type="text" id="year" required placeholder="e.g. 2nd Year">
            </div>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" rows="5" required placeholder="Your message here..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary w-full">Send Message</button>
        </form>
      </div>
      </div>
    </div>
  </section>
  </div>
</Layout>

<script>

  function initScrollAnimations() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.animate-fade-up').forEach(el => {
      observer.observe(el);
    });
  }

  function initContactForm() {
    const form = document.getElementById('contact-form');
    if (!form) return;
    
    const newForm = form.cloneNode(true);
    form.parentNode.replaceChild(newForm, form);
    
    newForm.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const btn = newForm.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
      btn.textContent = 'Sending...';
      btn.disabled = true;
      
      const formData = new FormData();
      formData.append('name', newForm.querySelector('#name').value);
      formData.append('Email', newForm.querySelector('#email').value);
      formData.append('Phone', newForm.querySelector('#phone').value);
      formData.append('Department', newForm.querySelector('#department').value);
      formData.append('Year', newForm.querySelector('#year').value);
      formData.append('Message', newForm.querySelector('#message').value);
      formData.append('Submission Time', new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', dateStyle: 'long', timeStyle: 'medium' }));
      
      fetch("https://script.google.com/macros/s/AKfycbwgnB-e2j-AaD5rhDmmqvAqrxCMlNE7wkfN6tqAjWJBNOrKBLUyIfYg7v6xMkUawbXQ/exec", {
          method: "POST",
          body: formData
      })
      .then(response => {
          alert("Thank you! Your message has been saved to the database.");
          newForm.reset();
          btn.textContent = originalText;
          btn.disabled = false;
      })
      .catch(error => {
          console.error(error);
          alert("Oops! Something went wrong.");
          btn.textContent = originalText;
          btn.disabled = false;
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initScrollAnimations();
    initContactForm();
  });
  document.addEventListener('astro:page-load', () => {
    initScrollAnimations();
    initContactForm();
  });
</script>

<style>
  .relative-z {
    position: relative;
    z-index: 10;
  }

  .animate-fade-up {
    opacity: 0;
    transform: translateY(30px);
  }
  
  .animate-fade-up.visible {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .page-header {
    background: transparent;
    padding: 6rem 0 4rem;
    border-bottom: none;
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .contact-info h2 {
    margin-bottom: 1rem;
  }
  
  .contact-info > p {
    margin-bottom: 2rem;
  }

  .info-item {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .info-item .icon {
    font-size: 2rem;
    background: rgba(0, 114, 206, 0.08);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--primary-color);
    border: 1px solid rgba(0, 114, 206, 0.1);
  }

  .info-item h4 {
    margin-bottom: 0.25rem;
    font-size: 1.1rem;
  }

  .info-item p {
    margin: 0;
  }

  .address-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .address-link:hover {
    color: var(--primary-color);
  }

  .map-container {
    margin-top: 2.5rem;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .contact-form {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 2.5rem;
    border-radius: 20px;
    box-shadow: 0 4px 30px rgba(0, 114, 206, 0.05);
    border: 1px solid rgba(0, 114, 206, 0.1);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--text-main);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(0, 114, 206, 0.2);
    border-radius: 10px;
    font-family: inherit;
    font-size: 1rem;
    color: var(--text-main);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.4) 100%);
    box-shadow: inset 0 2px 4px rgba(255, 255, 255, 0.9), 0 4px 12px rgba(0, 0, 0, 0.03);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease, background 0.3s ease;
  }

  .form-group div label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--text-main);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--primary-color);
    background: linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0.8) 100%);
    box-shadow: inset 0 2px 4px rgba(255, 255, 255, 0.9), 0 0 0 3px rgba(0, 114, 206, 0.15), 0 8px 20px rgba(0, 114, 206, 0.1);
    transform: translateY(-2px);
  }

  .w-full {
    width: 100%;
  }

  @media (max-width: 768px) {
    .contact-container {
      grid-template-columns: 1fr;
    }
  }
</style>
