---
import Layout from './Layout.astro';
import siteConfig from '../data/siteConfig.json';
const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <div class="cheatsheet-page-bg"></div>
  
  <div class="cheatsheet-wrapper">
    <!-- Removed Top Right ACM Logo -->

    <div class="header-actions">
      <div class="breadcrumb">
        <a href="/resources">← Back to Resources</a>
      </div>
      <button class="download-btn" onclick="window.print()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Download PDF
      </button>
    </div>

    <article class="markdown-body">
      <div class="cheatsheet-header">
        <h1>{frontmatter.title}</h1>
        <p class="description">{frontmatter.description}</p>
      </div>
      <slot />
    </article>
  </div>
</Layout>

  <script>
    // Auto-trigger print dialog if navigated with ?print=true
    if (typeof window !== 'undefined' && window.location.search.includes('print=true')) {
      window.addEventListener('load', () => {
        setTimeout(() => window.print(), 500);
      });
    }
  </script>

<style>
  .header-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  .cheatsheet-page-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    background-image: radial-gradient(rgba(0, 114, 206, 0.05) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  .cheatsheet-wrapper {
    max-width: 950px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
    position: relative;
    min-height: 100vh;
  }



  .download-btn {
    background: linear-gradient(135deg, var(--primary-color, #0072CE) 0%, #00d2ff 100%);
    color: white;
    border: none;
    padding: 0.75rem 1.75rem;
    border-radius: 99px;
    font-weight: 800;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 15px rgba(0, 114, 206, 0.3), inset 0 0 10px rgba(255, 255, 255, 0.2);
    position: relative;
    overflow: hidden;
  }

  .download-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    transition: left 0.5s ease;
  }

  .download-btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 8px 25px rgba(0, 114, 206, 0.5), inset 0 0 15px rgba(255, 255, 255, 0.4);
  }

  .download-btn:hover::before {
    left: 100%;
  }

  .download-btn svg {
    transition: transform 0.3s ease;
  }

  .download-btn:hover svg {
    transform: translateY(2px);
  }

  .breadcrumb {
    margin-bottom: 0;
  }
  
  .breadcrumb a {
    color: var(--primary-color, #0072CE);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    display: inline-flex;
    align-items: center;
    transition: transform 0.3s ease;
  }

  .breadcrumb a:hover {
    transform: translateX(-5px);
  }

  .markdown-body {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(0, 114, 206, 0.15);
    border-radius: 24px;
    padding: 4rem;
    box-shadow: 0 20px 60px rgba(0, 114, 206, 0.08), inset 0 0 20px rgba(255, 255, 255, 0.8);
    color: #334155;
    font-size: 1.05rem;
    line-height: 1.7;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .cheatsheet-header {
    text-align: center;
    margin-bottom: 3.5rem;
    border-bottom: 2px solid rgba(0, 114, 206, 0.1);
    padding-bottom: 2rem;
  }

  .markdown-body h1 { 
    font-size: 3rem; 
    color: #0f172a; 
    font-weight: 900; 
    margin-bottom: 1rem; 
    letter-spacing: -1px;
  }

  .markdown-body .description { 
    color: #64748b; 
    font-size: 1.25rem; 
    max-width: 600px;
    margin: 0 auto;
  }

  .markdown-body h2 { 
    font-size: 1.8rem; 
    color: var(--primary-color, #0072CE); 
    border-bottom: 2px solid rgba(0, 114, 206, 0.1); 
    padding-bottom: 0.5rem; 
    margin-top: 3rem; 
    margin-bottom: 1.5rem; 
    font-weight: 800;
  }

  .markdown-body h3 { 
    font-size: 1.4rem; 
    color: #0f172a; 
    margin-top: 2.5rem; 
    margin-bottom: 1rem; 
    font-weight: 700;
  }

  .markdown-body p { 
    margin-bottom: 1.25rem; 
  }

  .markdown-body ul, .markdown-body ol { 
    margin-left: 1.5rem; 
    margin-bottom: 1.5rem; 
  }
  
  .markdown-body li { 
    margin-bottom: 0.5rem; 
  }

  .markdown-body pre { 
    background: #0f172a !important; 
    padding: 1.5rem; 
    border-radius: 12px; 
    overflow-x: auto; 
    margin-top: 1rem;
    margin-bottom: 2rem; 
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .markdown-body code { 
    font-family: 'Fira Code', 'Consolas', monospace; 
    font-size: 0.95rem; 
    color: #e2e8f0;
  }

  /* Inline code styling */
  .markdown-body :not(pre) > code { 
    background: rgba(0, 114, 206, 0.1); 
    color: var(--primary-color, #0072CE); 
    padding: 0.2rem 0.4rem; 
    border-radius: 6px; 
    font-weight: 600; 
    font-size: 0.9em;
  }

  .markdown-body table { 
    width: 100%; 
    border-collapse: separate; 
    border-spacing: 0;
    margin-bottom: 2.5rem; 
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0, 114, 206, 0.15);
  }

  .markdown-body th, .markdown-body td { 
    padding: 1rem 1.25rem; 
    text-align: left; 
    border-bottom: 1px solid rgba(0, 114, 206, 0.1); 
  }

  .markdown-body th { 
    background: rgba(0, 114, 206, 0.05); 
    color: var(--primary-color, #0072CE); 
    font-weight: 800; 
  }

  .markdown-body tr:last-child td {
    border-bottom: none;
  }

  .markdown-body tr:hover td { 
    background: rgba(0, 114, 206, 0.02); 
  }

  .markdown-body blockquote { 
    border-left: 4px solid var(--primary-color, #0072CE); 
    margin: 1.5rem 0; 
    color: #475569; 
    font-style: italic; 
    background: rgba(0, 114, 206, 0.03); 
    padding: 1.25rem 1.5rem; 
    border-radius: 0 12px 12px 0; 
  }

  @media (max-width: 768px) {
    .cheatsheet-wrapper { padding: 5rem 1rem 2rem; }
    .header-actions { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .markdown-body { padding: 2rem 1.5rem; }
    .markdown-body h1 { font-size: 2.2rem; }
    .cheatsheet-header { margin-bottom: 2rem; }
  }

  /* --- Print Styles for PDF Export --- */
  @media print {
    .cheatsheet-page-bg, .breadcrumb, .download-btn {
      display: none !important;
    }
    
    body {
      background: #fff !important;
    }

    .cheatsheet-wrapper {
      padding: 0 !important;
      margin: 0 !important;
      max-width: 100% !important;
    }

    .markdown-body {
      border: none !important;
      box-shadow: none !important;
      padding: 0 !important;
      background: transparent !important;
      color: #000 !important;
    }



    /* Print colors for syntax highlighting */
    .markdown-body pre {
      background: #f8f9fa !important;
      border: 1px solid #dee2e6 !important;
      color: #000 !important;
      page-break-inside: avoid;
    }
    
    .markdown-body code {
      color: #000 !important;
    }

    .markdown-body :not(pre) > code {
      background: #f1f3f5 !important;
      color: #000 !important;
      border: 1px solid #dee2e6 !important;
    }

    .markdown-body a {
      text-decoration: underline !important;
      color: #000 !important;
    }

    h1, h2, h3, p, li {
      page-break-inside: avoid;
    }
  }
</style>
