---
// Subtle Dot Grid Background Component
---
<div class="page-background" transition:persist="wave-bg">
  <div class="dot-grid"></div>
  <div class="gradient-overlay"></div>
</div>

<style>
  .page-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    overflow: hidden;
    background-color: #ffffff;
    pointer-events: none;
  }

  .dot-grid {
    position: absolute;
    inset: 0;
    /* Slightly darker dots and slightly larger so they are visible */
    background-image: radial-gradient(circle, #94a3b8 1.5px, transparent 2px);
    background-size: 28px 28px;
    background-position: center center;
    opacity: 0.4;
  }

  .gradient-overlay {
    position: absolute;
    inset: 0;
    /* Less aggressive fade to allow the grid to show clearly */
    background: linear-gradient(to bottom, transparent 80%, #ffffff 100%);
    pointer-events: none;
    z-index: 1;
  }
</style>
