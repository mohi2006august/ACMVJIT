---
// Global 3D Wave Background Component
---
<div class="page-background" transition:persist="wave-bg">
  <canvas id="global-wave-canvas"></canvas>
  <div class="gradient-overlay-wave"></div>
</div>

<script>
  function initGlobalWave() {
    const canvas = document.getElementById('global-wave-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    
    let width, height;
    function resize() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    }
    window.addEventListener('resize', resize);
    resize();
    
    const isMobile = window.innerWidth < 768;
    // Massive grid size to prevent bottom cut-offs on scaled mobile desktop modes
    const rows = isMobile ? 35 : 65;
    const cols = isMobile ? 45 : 85;
    const spacing = isMobile ? 50 : 40;
    const points = [];
    
    for (let z = 0; z < rows; z++) {
      for (let x = 0; x < cols; x++) {
        points.push({
          x: (x - cols / 2) * spacing,
          z: (z - rows / 2) * spacing,
          y: 0
        });
      }
    }
    
    let time = 0;
    let targetRotX = 1.1; 
    let targetRotY = 0;
    let rotX = 1.1;
    let rotY = 0;
    
    window.addEventListener('mousemove', (e) => {
      const mouseX = e.clientX - width / 2;
      const mouseY = e.clientY - height / 2;
      targetRotY = mouseX * 0.0002;
      targetRotX = 1.1 + mouseY * 0.0002;
    });
    
    window.addEventListener('mouseleave', () => {
      targetRotY = 0;
      targetRotX = 1.1;
    });
    
    let animationId;
    let isAnimating = true;

    function animate() {
      if (!isAnimating) return;
      ctx.clearRect(0, 0, width, height);
      time += 0.008; 
      
      rotX += (targetRotX - rotX) * 0.02;
      rotY += (targetRotY - rotY) * 0.02;
      
      const cosX = Math.cos(rotX);
      const sinX = Math.sin(rotX);
      const cosY = Math.cos(rotY);
      const sinY = Math.sin(rotY);
      
      const points2D = [];
      
      for (let z = 0; z < rows; z++) {
        points2D[z] = [];
        for (let x = 0; x < cols; x++) {
          const index = z * cols + x;
          const p = points[index];
          
          const y = Math.sin(p.x * 0.015 + time) * 60 + Math.cos(p.z * 0.02 + time) * 50;
          
          const x1 = p.x * cosY + p.z * sinY;
          const z1 = -p.x * sinY + p.z * cosY;
          
          const y2 = y * cosX - z1 * sinX;
          const z2 = y * sinX + z1 * cosX;
          
          const distance = 1200; 
          const scale = 1000 / (distance + z2);
          const x3 = x1 * scale + width / 2;
          const y3 = y2 * scale + height / 2 + 150; 
          
          points2D[z].push({ x: x3, y: y3, z: z2, h: y });
        }
      }
      
      for (let z = 0; z < rows - 1; z++) {
        for (let x = 0; x < cols - 1; x++) {
          const p = points2D[z][x];
          const right = points2D[z][x+1];
          const down = points2D[z+1][x];
          
          const opacity = Math.max(0, 1 - (p.z / 800));
          if (opacity <= 0.01) continue;
          
          const intensity = Math.max(0, Math.min(1, (p.h + 100) / 200));
          const r = 0;
          const g = Math.floor(114 + (210 - 114) * intensity);
          const b = Math.floor(206 + (255 - 206) * intensity);
          
          ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${opacity * 0.6})`;
          ctx.lineWidth = intensity > 0.6 ? 2 : 1;
          
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(right.x, right.y);
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(down.x, down.y);
          ctx.stroke();
          
          if (intensity > 0.8) {
            ctx.beginPath();
            ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(0, 255, 255, ${opacity})`;
            ctx.shadowBlur = 10;
            ctx.shadowColor = '#00ffff';
            ctx.fill();
            ctx.shadowBlur = 0;
          }
        }
      }
      
      animationId = requestAnimationFrame(animate);
    }
    
    // Check if we are still on the page before animating
    if(document.body.contains(canvas)) {
        animate();
    }
    
    document.addEventListener('astro:before-swap', () => {
      isAnimating = false;
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', resize);
    }, { once: true });
  }

  // Only init once to prevent multiple overlapping event listeners across navigation
  if (!window.waveInitialized) {
      document.addEventListener('DOMContentLoaded', initGlobalWave);
      document.addEventListener('astro:page-load', initGlobalWave);
      window.waveInitialized = true;
  }
</script>

<style>
  .page-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    overflow: hidden;
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    pointer-events: none;
  }

  #global-wave-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .gradient-overlay-wave {
    position: absolute;
    inset: 0;
    /* Smooth transition to pure white at the bottom prevents hard cutoffs */
    background: 
      radial-gradient(circle at center, transparent 0%, rgba(255,255,255,0.6) 100%),
      linear-gradient(to bottom, transparent 65%, #ffffff 98%);
    pointer-events: none;
    z-index: 1;
  }
</style>
